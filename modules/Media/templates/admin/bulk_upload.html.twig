{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Bulk upload slika{% endblock %}

{% block main %}
    <div class="card"
         data-controller="media--bulk-upload"
         data-media--bulk-upload-upload-url-value="{{ path('media_upload') }}"
         data-media--bulk-upload-csrf-token-value="{{ csrf_token('media_upload') }}">
        <div class="card-body" style="max-width: 48rem;">
            <p class="text-muted">
                Povuci više slika odjednom (ili klikni za odabir). Svaka uspješna slika
                postaje novi medij. Dozvoljeno: JPG, PNG, WEBP, GIF do 5 MB.
            </p>

            <input type="file" multiple accept="image/*" data-media--bulk-upload-target="fileInput">

            <p class="mt-3" hidden>
                Učitano: <span class="badge badge-success" data-media--bulk-upload-target="count">0</span>
            </p>

            <a href="{{ ea_url().setController('Tallyst\\Media\\Controller\\Admin\\MediaCrudController').setAction('index') }}"
               class="btn btn-primary mt-2">Idi na popis medija</a>
        </div>
    </div>
{% endblock %}
