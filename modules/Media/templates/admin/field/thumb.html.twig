{# Liip "thumb" preview for the Media list/detail. field.value = imageName.
   media_thumb_url() returns the DIRECT cached file URL (warmed on upload) — a real
   static file nginx serves; not the on-demand resolve URL (which nginx 404s). #}
{% set src = media_thumb_url(field.value, 'thumb') %}
{% if src %}
    <img src="{{ src }}" alt="" loading="lazy"
         style="max-height: 64px; max-width: 120px; border-radius: 4px; object-fit: cover;">
{% else %}
    <span class="text-muted">—</span>
{% endif %}
