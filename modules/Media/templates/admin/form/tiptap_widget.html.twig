{# Form-theme block for TiptapType (block_prefix = tiptap). Renders the real textarea
   (form-bound, visually hidden) + a toolbar + the editor mount, plus the reusable Pass A
   media-library modal for "insert image". The media--tiptap controller mounts Tiptap,
   syncs the editor HTML into the textarea, and listens for media-library:select scoped to
   THIS subtree (so it never crosses with the featured-image picker on the same form). #}
{% block tiptap_widget %}
    <div class="tiptap"
         data-controller="media--tiptap"
         data-media--tiptap-modules-value="{{ enabled_modules() }}"
         data-media--tiptap-link-targets-url-value="{{ path('admin_link_targets') }}"
         data-media--tiptap-link-type-page-value="{{ 'admin.media.tiptap.link_type_page'|trans({}, 'admin') }}"
         data-media--tiptap-link-type-post-value="{{ 'admin.media.tiptap.link_type_post'|trans({}, 'admin') }}"
         data-media--tiptap-link-loading-value="{{ 'admin.media.tiptap.link_loading'|trans({}, 'admin') }}"
         data-media--tiptap-link-none-value="{{ 'admin.media.tiptap.link_none'|trans({}, 'admin') }}"
         data-media--tiptap-link-load-error-value="{{ 'admin.media.tiptap.link_load_error'|trans({}, 'admin') }}"
         data-action="media-library:select->media--tiptap#onMediaSelect">

        <div class="tiptap__toolbar" role="toolbar">
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.bold'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.bold'|trans({}, 'admin') }}" data-action="media--tiptap#bold"><i class="fa-solid fa-bold" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.italic'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.italic'|trans({}, 'admin') }}" data-action="media--tiptap#italic"><i class="fa-solid fa-italic" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.strike'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.strike'|trans({}, 'admin') }}" data-action="media--tiptap#strike"><i class="fa-solid fa-strikethrough" aria-hidden="true"></i></button>
            <span class="tiptap__sep"></span>

            {# Heading dropdown: Paragraph / H1–H4 (sets the block, doesn't toggle). #}
            <div class="tiptap__dropdown">
                <button type="button" class="tiptap__btn tiptap__btn--dd" title="{{ 'admin.media.tiptap.heading'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.heading'|trans({}, 'admin') }}"
                        aria-haspopup="true" aria-expanded="false" data-action="media--tiptap#toggleDropdown"><i class="fa-solid fa-heading" aria-hidden="true"></i><i class="fa-solid fa-caret-down tiptap__caret" aria-hidden="true"></i></button>
                <div class="tiptap__menu" role="menu">
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-level="0" data-action="media--tiptap#setHeading">{{ 'admin.media.tiptap.paragraph'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-level="1" data-action="media--tiptap#setHeading"><b>{{ 'admin.media.tiptap.h1'|trans({}, 'admin') }}</b></button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-level="2" data-action="media--tiptap#setHeading">{{ 'admin.media.tiptap.h2'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-level="3" data-action="media--tiptap#setHeading">{{ 'admin.media.tiptap.h3'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-level="4" data-action="media--tiptap#setHeading">{{ 'admin.media.tiptap.h4'|trans({}, 'admin') }}</button>
                </div>
            </div>

            {# List dropdown: bullet / numbered. #}
            <div class="tiptap__dropdown">
                <button type="button" class="tiptap__btn tiptap__btn--dd" title="{{ 'admin.media.tiptap.list'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.list'|trans({}, 'admin') }}"
                        aria-haspopup="true" aria-expanded="false" data-action="media--tiptap#toggleDropdown"><i class="fa-solid fa-list-ul" aria-hidden="true"></i><i class="fa-solid fa-caret-down tiptap__caret" aria-hidden="true"></i></button>
                <div class="tiptap__menu" role="menu">
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-list="bullet" data-action="media--tiptap#setList">&bull; {{ 'admin.media.tiptap.bullet_list'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-list="ordered" data-action="media--tiptap#setList">1. {{ 'admin.media.tiptap.ordered_list'|trans({}, 'admin') }}</button>
                </div>
            </div>

            {# Text-align dropdown: left / center / right / justify (paragraphs + headings). #}
            <div class="tiptap__dropdown">
                <button type="button" class="tiptap__btn tiptap__btn--dd" title="{{ 'admin.media.tiptap.align'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.align'|trans({}, 'admin') }}"
                        aria-haspopup="true" aria-expanded="false" data-action="media--tiptap#toggleDropdown"><i class="fa-solid fa-align-left" aria-hidden="true"></i><i class="fa-solid fa-caret-down tiptap__caret" aria-hidden="true"></i></button>
                <div class="tiptap__menu" role="menu">
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-align="left" data-action="media--tiptap#setAlign">{{ 'admin.media.tiptap.align_left'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-align="center" data-action="media--tiptap#setAlign">{{ 'admin.media.tiptap.align_center'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-align="right" data-action="media--tiptap#setAlign">{{ 'admin.media.tiptap.align_right'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-align="justify" data-action="media--tiptap#setAlign">{{ 'admin.media.tiptap.align_justify'|trans({}, 'admin') }}</button>
                </div>
            </div>
            <span class="tiptap__sep"></span>

            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.blockquote'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.blockquote'|trans({}, 'admin') }}" data-action="media--tiptap#blockquote"><i class="fa-solid fa-quote-right" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.code'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.code'|trans({}, 'admin') }}" data-action="media--tiptap#code"><i class="fa-solid fa-code" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.hr'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.hr'|trans({}, 'admin') }}" data-action="media--tiptap#insertHr"><i class="fa-solid fa-minus" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.clear'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.clear'|trans({}, 'admin') }}" data-action="media--tiptap#clearFormatting"><i class="fa-solid fa-eraser" aria-hidden="true"></i></button>
            <span class="tiptap__sep"></span>

            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.link'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.link'|trans({}, 'admin') }}" data-action="media--tiptap#link"><i class="fa-solid fa-link" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.unlink'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.unlink'|trans({}, 'admin') }}" data-action="media--tiptap#unlink"><i class="fa-solid fa-link-slash" aria-hidden="true"></i></button>
            <span class="tiptap__sep"></span>

            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.insert_image'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.insert_image'|trans({}, 'admin') }}" data-action="media--tiptap#insertImage"><i class="fa-solid fa-image" aria-hidden="true"></i></button>

            {# ONE consolidated "IMG format" dropdown for a SELECTED image — alignment + a single
               size scale (Small/Medium/Large/Full). No-op without a selected image. Pure UI: it sets
               the image node's existing data-align / data-size / data-width attributes, the same the
               converter already round-trips into [image align/size/width] for the front. The size
               scale folds the old standalone "Full width" toggle into its top step (Full = width=full,
               which the front already treats as the top of the scale, overriding size). #}
            <div class="tiptap__dropdown">
                <button type="button" class="tiptap__btn tiptap__btn--dd" title="{{ 'admin.media.tiptap.img_format'|trans({}, 'admin') }}"
                        data-media--tiptap-target="imageFormat"
                        aria-haspopup="true" aria-expanded="false" data-action="media--tiptap#toggleDropdown"><i class="fa-solid fa-photo-film" aria-hidden="true"></i> {{ 'admin.media.tiptap.img_format'|trans({}, 'admin') }}<i class="fa-solid fa-caret-down tiptap__caret" aria-hidden="true"></i></button>
                <div class="tiptap__menu" role="menu">
                    <span class="tiptap__menu-header">{{ 'admin.media.tiptap.img_group_align'|trans({}, 'admin') }}</span>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-align="left" data-action="media--tiptap#setImageAlign">{{ 'admin.media.tiptap.img_align_left'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-align="center" data-action="media--tiptap#setImageAlign">{{ 'admin.media.tiptap.img_align_center'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-align="right" data-action="media--tiptap#setImageAlign">{{ 'admin.media.tiptap.img_align_right'|trans({}, 'admin') }}</button>
                    <span class="tiptap__menu-sep"></span>
                    <span class="tiptap__menu-header">{{ 'admin.media.tiptap.img_group_size'|trans({}, 'admin') }}</span>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-size="thumb" data-action="media--tiptap#setImageSize">{{ 'admin.media.tiptap.img_size_small'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-size="medium" data-action="media--tiptap#setImageSize">{{ 'admin.media.tiptap.img_size_medium'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-size="hero" data-action="media--tiptap#setImageSize">{{ 'admin.media.tiptap.img_size_large'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-img-size="full" data-action="media--tiptap#setImageSize">{{ 'admin.media.tiptap.img_size_full'|trans({}, 'admin') }}</button>
                </div>
            </div>
            <span class="tiptap__sep"></span>

            {# Multi-column layout (Prolaz C) — core editor feature, always present (not
               module-gated): insert a fixed 2/3/4-column block at the cursor. #}
            <div class="tiptap__dropdown">
                <button type="button" class="tiptap__btn tiptap__btn--dd" title="{{ 'admin.media.tiptap.columns'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.columns'|trans({}, 'admin') }}"
                        aria-haspopup="true" aria-expanded="false" data-action="media--tiptap#toggleDropdown"><i class="fa-solid fa-table-columns" aria-hidden="true"></i><i class="fa-solid fa-caret-down tiptap__caret" aria-hidden="true"></i></button>
                <div class="tiptap__menu" role="menu">
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-count="2" data-action="media--tiptap#addColumns">{{ 'admin.media.tiptap.columns2'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-count="3" data-action="media--tiptap#addColumns">{{ 'admin.media.tiptap.columns3'|trans({}, 'admin') }}</button>
                    <button type="button" class="tiptap__menu-item" role="menuitem" data-count="4" data-action="media--tiptap#addColumns">{{ 'admin.media.tiptap.columns4'|trans({}, 'admin') }}</button>
                </div>
            </div>
            {# Module-contributed insert buttons (e.g. FormBuilder "Insert form") are
               appended here by the controller — the editor stays module-agnostic. The label of
               that button + the form-picker modal are wired at bootstrap (NOT on a Twig element),
               so their text is the one remaining un-translated JS spot — see CLAUDE.md i18n note. #}
            <span class="tiptap__ext" data-media--tiptap-target="toolbar"></span>
            <span class="tiptap__sep"></span>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.undo'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.undo'|trans({}, 'admin') }}" data-action="media--tiptap#undo"><i class="fa-solid fa-rotate-left" aria-hidden="true"></i></button>
            <button type="button" class="tiptap__btn" title="{{ 'admin.media.tiptap.redo'|trans({}, 'admin') }}" aria-label="{{ 'admin.media.tiptap.redo'|trans({}, 'admin') }}" data-action="media--tiptap#redo"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i></button>
        </div>

        <div class="tiptap__editor" data-media--tiptap-target="editor"></div>

        {# The real form field — kept in the DOM, hidden, synced from the editor. #}
        <textarea {{ block('widget_attributes') }} data-media--tiptap-target="input"
                  hidden>{{ value }}</textarea>

        {{ include('@Media/admin/_media_library_modal.html.twig', { tiptap_target: true }) }}
        {{ include('@Media/admin/form/_link_picker_modal.html.twig') }}
    </div>
{% endblock %}
