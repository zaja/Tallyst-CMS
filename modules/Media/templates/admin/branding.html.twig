{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block content_title %}Branding{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body" style="max-width: 32rem;">
            {{ form_start(form) }}
            {{ form_row(form.logo) }}
            <p class="text-muted small">Naziv sajta se uređuje u <a href="{{ path('admin_settings') }}">Postavke → Općenito</a>.</p>
            <button class="btn btn-primary" type="submit">Spremi</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
