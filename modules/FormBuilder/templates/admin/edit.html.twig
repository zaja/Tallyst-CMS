{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block content_title %}{{ definition.id ? 'Uredi formu' : 'Nova forma' }}{% endblock %}

{% block main %}
    <div data-controller="formbuilder--builder">
        {{ form_start(form) }}

        <div class="card mb-3">
            <div class="card-body">
                {{ form_errors(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.slug) }}
                {{ form_row(form.description) }}
                {{ form_row(form.status) }}
                <div class="row">
                    <div class="col">{{ form_row(form.priceMinor) }}</div>
                    <div class="col">{{ form_row(form.currency) }}</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h5">Polja</h2>
                {{ form_errors(form.fields) }}

                {# datalist hint of existing field keys for the condition "field" inputs #}
                <datalist id="fb-field-keys">
                    {% for fieldForm in form.fields %}
                        <option value="{{ fieldForm.vars.value.key }}"></option>
                    {% endfor %}
                </datalist>

                <div data-fb-collection data-fb-level="fields"
                     data-prototype="{{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: form.fields.vars.prototype})|e('html_attr') }}"
                     data-prototype-name="__field__"
                     data-fb-index="{{ form.fields|length }}">
                    <div data-fb-items>
                        {% for fieldForm in form.fields %}
                            {{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: fieldForm}) }}
                        {% endfor %}
                    </div>
                    <button type="button" class="btn btn-outline-secondary mt-2" data-action="formbuilder--builder#add">+ Dodaj polje</button>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Spremi</button>
            <a class="btn btn-light" href="{{ path('form_builder_admin_index') }}">Odustani</a>
        </div>

        {# We render every field manually above; render only the CSRF token from the
           rest, and disable form_rest so it doesn't re-emit the fields collection as
           empty index-labelled fieldsets ("0 1 2" under the Save button). #}
        {{ form_widget(form._token) }}
        {{ form_end(form, {render_rest: false}) }}
    </div>

    <style>
        .fb-field-row { border: 1px solid #e5e7eb; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; background: #fcfcfd; }
        .fb-row-head { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .5rem; }
        .fb-handle { color: #9ca3af; }
        /* Collapsed-by-default field rows: a clickable summary toggles the config open. */
        .fb-row-summary { display: flex; align-items: center; gap: .5rem; cursor: pointer; flex: 1; min-width: 0; }
        .fb-summary-label { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .fb-row-controls { display: flex; gap: .25rem; flex-shrink: 0; }
        .fb-chevron::before { content: '▾'; color: #6b7280; font-size: .8rem; }
        .fb-field-row--collapsed .fb-chevron::before { content: '▸'; }
        .fb-field-row--collapsed .fb-row-head { margin-bottom: 0; }
        .fb-field-row--collapsed .fb-grid,
        .fb-field-row--collapsed .fb-cond { display: none; }
        .fb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem 1rem; }
        .fb-cond { margin-top: 1rem; border: 1px dashed #d1d5db; border-radius: 8px; padding: .75rem; }
        .fb-cond legend { font-size: .85rem; color: #555; width: auto; padding: 0 .4rem; }
        .fb-cond-head { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .fb-rule { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: .5rem; align-items: start; margin-bottom: .5rem; }
        .fb-rule .mb-3 { margin-bottom: 0 !important; }
    </style>
{% endblock %}
