<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ definition.id ? 'Uredi formu' : 'Nova forma' }} — Tallyst Admin</title>
    {{ importmap('app') }}
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f3f4f6; color: #1a1a1a; margin: 0; }
        .wrap { max-width: 880px; margin: 0 auto; padding: 2rem 1.25rem; }
        a { color: #2563eb; text-decoration: none; }
        h1 { font-size: 1.4rem; }
        label { font-weight: 600; font-size: .9rem; display: block; margin-bottom: .2rem; }
        input[type=text], input[type=email], select, textarea { width: 100%; padding: .5rem .6rem; border: 1px solid #d1d5db; border-radius: 7px; font: inherit; }
        textarea { min-height: 3.5rem; }
        .card { background: #fff; border-radius: 10px; padding: 1.25rem; box-shadow: 0 1px 3px rgba(0,0,0,.08); margin-bottom: 1.25rem; }
        .btn { background: #2563eb; color: #fff; border: 0; border-radius: 8px; padding: .55rem 1rem; cursor: pointer; font: inherit; }
        .btn.secondary { background: #e5e7eb; color: #111; }
        button { font: inherit; }
        .fb-field-row { border: 1px solid #e5e7eb; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; background: #fcfcfd; }
        .fb-row-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
        .fb-handle { color: #9ca3af; }
        .fb-row-controls button { border: 1px solid #d1d5db; background: #fff; border-radius: 6px; padding: .25rem .5rem; cursor: pointer; }
        .fb-del { color: #b91c1c; }
        .fb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
        .fb-grid > div { margin: 0; }
        .fb-cond { margin-top: 1rem; border: 1px dashed #d1d5db; border-radius: 8px; padding: .75rem; }
        .fb-cond legend { font-size: .85rem; color: #555; padding: 0 .4rem; }
        .fb-cond-head { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: .5rem; }
        .fb-rule { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: .5rem; align-items: center; margin-bottom: .5rem; }
        .fb-x { border: 0; background: #fee2e2; color: #b91c1c; border-radius: 6px; padding: .3rem .55rem; cursor: pointer; }
        .fb-add-rule { border: 1px dashed #93c5fd; background: #eff6ff; color: #1d4ed8; border-radius: 6px; padding: .3rem .6rem; cursor: pointer; }
        .errors { color: #b91c1c; font-size: .9rem; }
        .actions { display: flex; gap: .5rem; }
    </style>
</head>
<body>
    <div class="wrap" data-controller="formbuilder--builder">
        <p><a href="{{ path('form_builder_admin_index') }}">&larr; Sve forme</a></p>
        <h1>{{ definition.id ? 'Uredi formu' : 'Nova forma' }}</h1>

        {{ form_start(form) }}

        <div class="card">
            {{ form_errors(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.slug) }}
            {{ form_row(form.description) }}
            {{ form_row(form.status) }}
        </div>

        <div class="card">
            <h2>Polja</h2>
            {{ form_errors(form.fields) }}

            {# datalist hint of existing field keys for the condition "field" inputs #}
            <datalist id="fb-field-keys">
                {% for fieldForm in form.fields %}
                    <option value="{{ fieldForm.vars.value.key }}"></option>
                {% endfor %}
            </datalist>

            <div data-fb-collection data-fb-level="fields"
                 data-prototype="{{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: form.fields.vars.prototype})|e('html_attr') }}"
                 data-prototype-name="__field__"
                 data-fb-index="{{ form.fields|length }}">
                <div data-fb-items>
                    {% for fieldForm in form.fields %}
                        {{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: fieldForm}) }}
                    {% endfor %}
                </div>
                <button type="button" class="btn secondary" data-action="formbuilder--builder#add">+ Dodaj polje</button>
            </div>
        </div>

        <div class="actions">
            <button class="btn" type="submit">Spremi</button>
            <a class="btn secondary" href="{{ path('form_builder_admin_index') }}">Odustani</a>
        </div>

        {{ form_end(form) }}
    </div>
</body>
</html>
