{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form '@EasyAdmin/crud/form_theme.html.twig' %}

{% block content_title %}{{ (definition.id ? 'admin.form.builder.edit_title' : 'admin.form.builder.new_title')|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {# UI-only: open in "Paid" when the form carries ANY non-empty paid configuration (price/variants —
       isProduct — OR explicitly chosen payment methods / shipping methods / ship-to countries / a Dodo
       product). Empty defaults do NOT count. The backend's product decision (has price or variants) is
       UNCHANGED — this only picks which sections the builder reveals; see form_type_controller.js. #}
    {% set fbValue = form.vars.value %}
    {% set isProduct = fbValue.isProduct()
        or fbValue.getAllowedPaymentMethods()
        or fbValue.getShippingMethods()
        or fbValue.getAllowedShippingCountries()
        or fbValue.getDodoProductId() %}
    {# The builder controller's JS-generated "new field" summary fallback is fed the translated label
       as a Stimulus value (Twig owns the translation; JS reads it). #}
    <div data-controller="formbuilder--builder formbuilder--formtype"
         data-action="input->formbuilder--formtype#refresh change->formbuilder--formtype#refresh"
         data-formbuilder--builder-new-field-label-value="{{ 'admin.form.field.new'|trans({}, 'admin') }}">
        {{ form_start(form, {attr: {'data-dirty-guard': ''}}) }}

        {# Osnovno #}
        <div class="card mb-3 fb-card">
            <div class="card-body">
                <h2 class="h5 fb-section-title">{{ 'admin.form.builder.basic.title'|trans({}, 'admin') }}</h2>
                <p class="fb-section-help">{{ 'admin.form.builder.basic.help'|trans({}, 'admin') }}</p>
                {{ form_errors(form) }}
                {{ form_row(form.name) }}
                <div class="row">
                    <div class="col">{{ form_row(form.slug) }}</div>
                    <div class="col">{{ form_row(form.status) }}</div>
                </div>
                {{ form_row(form.description) }}
            </div>
        </div>

        {# Tip forme — UI-only toggle (buttons, nothing submitted) #}
        <div class="card mb-3 fb-card">
            <div class="card-body">
                <h2 class="h5 fb-section-title">{{ 'admin.form.builder.type.title'|trans({}, 'admin') }}</h2>
                <p class="fb-section-help">{{ 'admin.form.builder.type.help'|trans({}, 'admin') }}</p>
                <div class="fb-type-grid" role="group">
                    <button type="button" class="fb-type-option" data-fb-type="free"
                            data-formbuilder--formtype-target="option"
                            data-action="formbuilder--formtype#select"{{ isProduct ? '' : ' data-active' }}>
                        <span class="fb-type-title">{{ 'admin.form.builder.type.free'|trans({}, 'admin') }}</span>
                        <span class="fb-type-sub">{{ 'admin.form.builder.type.free_sub'|trans({}, 'admin') }}</span>
                    </button>
                    <button type="button" class="fb-type-option" data-fb-type="paid"
                            data-formbuilder--formtype-target="option"
                            data-action="formbuilder--formtype#select"{{ isProduct ? ' data-active' : '' }}>
                        <span class="fb-type-title">{{ 'admin.form.builder.type.paid'|trans({}, 'admin') }}</span>
                        <span class="fb-type-sub">{{ 'admin.form.builder.type.paid_sub'|trans({}, 'admin') }}</span>
                    </button>
                </div>
            </div>
        </div>

        {# Naplata (paid) — pre-hidden in Twig when not a product to avoid a flash before JS boots.
           data-controller: dodo-prefill (copies a picked Dodo product's price/currency) +
           payment-exclusive (a MoR method can't mix with Stripe/PayPal). #}
        <div class="card mb-3 fb-card{{ isProduct ? '' : ' d-none' }}" data-formbuilder--formtype-target="paid"
             data-controller="formbuilder--dodo-prefill formbuilder--payment-exclusive">
            <div class="card-body">
                <h2 class="h5 fb-section-title">{{ 'admin.form.builder.payment.title'|trans({}, 'admin') }} <span class="badge fb-badge-soft">{{ 'admin.form.builder.payment.badge'|trans({}, 'admin') }}</span></h2>
                <p class="fb-section-help">{{ 'admin.form.builder.payment.help'|trans({}, 'admin') }}</p>
                <div class="row">
                    <div class="col">{{ form_row(form.priceMinor) }}</div>
                    <div class="col">{{ form_row(form.currency) }}</div>
                </div>
                {# Gentle, NON-blocking note: shown (live) only when Paid is active but there's no price and
                   no variant. Never blocks saving; doesn't touch the backend. #}
                <p class="text-muted small mb-3 d-none" data-formbuilder--formtype-target="priceHint">
                    <i class="fa fa-circle-info"></i> {{ 'admin.form.builder.payment.price_hint'|trans({}, 'admin') }}
                </p>
                {{ form_row(form.allowedPaymentMethods) }}

                {# Dodo (Merchant-of-Record) per-form product. Dropdown from the live catalogue when
                   Dodo is configured, else a manual product-id input — always saveable. Explicit
                   render_row: form_end uses render_rest:false, so an unrendered field would vanish. #}
                {{ form_row(form.dodoProductId) }}
                <p class="text-muted small mb-3">{{ 'admin.form.def.dodo_price_note'|trans({}, 'admin') }}</p>

                {{ form_errors(form.variants) }}
                <div class="fb-subblock">
                    <p class="fb-section-help mb-2">{{ 'admin.form.builder.payment.variants_help'|trans({}, 'admin') }}</p>
                    <div data-fb-collection data-fb-level="variants"
                         data-prototype="{{ include('@FormBuilder/admin/_variant_row.html.twig', {variantForm: form.variants.vars.prototype})|e('html_attr') }}"
                         data-prototype-name="__variant__"
                         data-fb-index="{{ form.variants|length }}">
                        <div data-fb-items>
                            {% for variantForm in form.variants %}
                                {{ include('@FormBuilder/admin/_variant_row.html.twig', {variantForm: variantForm}) }}
                            {% endfor %}
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" data-action="formbuilder--builder#add">{{ 'admin.form.builder.add_variant'|trans({}, 'admin') }}</button>
                    </div>
                </div>

                {# Per-form tax rate (Faza 3): a single dropdown. Placeholder = the catalog DEFAULT rate
                   (empty value → null → backward-compat); named rates; "no tax". OMITTED server-side on a
                   MoR form (guard on presence) and hidden LIVE when Dodo is picked (formtype "tax" target).
                   render_row explicit — form_end uses render_rest:false, so an unrendered field vanishes. #}
                {% if form.taxRateKey is defined %}
                    <div class="fb-subblock" data-formbuilder--formtype-target="tax">
                        {{ form_row(form.taxRateKey) }}
                    </div>
                {% endif %}

                {# Shipping offer: which catalog methods this form shows at checkout. OMITTED from the form
                   on a MoR (Dodo) form (shipping is meaningless there), so guard on field presence; a
                   muted note when the catalog is empty. #}
                {% if form.shippingMethods is defined %}
                    {# Hidden LIVE by formbuilder--formtype when Dodo is selected (a MoR form has no Tallyst
                       shipping). A saved Dodo form omits this field server-side, so this only covers the
                       live intermediate step. #}
                    <div class="fb-subblock" data-formbuilder--formtype-target="shipping">
                        {{ form_row(form.shippingMethods) }}
                        {% if shipping_methods() is empty %}
                            <p class="text-muted small mb-0">{{ 'admin.form.def.shipping_none'|trans({}, 'admin') }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                {# Ship-to countries (Faza 2): present only when the form offers delivery (field added by the
                   type only for a non-MoR form that hasShipping). ~250 checkboxes made usable with search +
                   EU/All/None presets + a live count (formbuilder--country-select). Empty = ships everywhere. #}
                {% if form.allowedShippingCountries is defined %}
                    {# Pre-hidden: revealed live by formbuilder--formtype only when a delivery method is
                       checked (no flash for the common no-shipping case). #}
                    <div class="fb-subblock d-none" data-controller="formbuilder--country-select"
                         data-formbuilder--formtype-target="countries"
                         data-formbuilder--country-select-count-label-value="{{ 'admin.form.def.countries.selected'|trans({}, 'admin')|e('html_attr') }}">
                        <label class="form-label fw-semibold mb-1">{{ 'admin.form.def.shipping_countries'|trans({}, 'admin') }}</label>
                        <p class="fb-section-help mb-2">{{ 'admin.form.def.shipping_countries_help'|trans({}, 'admin') }}</p>
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                            <input type="search" class="form-control form-control-sm" style="max-width: 16rem"
                                   data-formbuilder--country-select-target="search"
                                   data-action="input->formbuilder--country-select#filter"
                                   placeholder="{{ 'admin.form.def.countries.search'|trans({}, 'admin') }}">
                            <button type="button" class="btn btn-sm btn-secondary" data-action="formbuilder--country-select#selectEu">{{ 'admin.form.def.countries.preset_eu'|trans({}, 'admin') }}</button>
                            <button type="button" class="btn btn-sm btn-secondary" data-action="formbuilder--country-select#selectAll">{{ 'admin.form.def.countries.preset_all'|trans({}, 'admin') }}</button>
                            <button type="button" class="btn btn-sm btn-secondary" data-action="formbuilder--country-select#selectNone">{{ 'admin.form.def.countries.preset_none'|trans({}, 'admin') }}</button>
                            <span class="text-muted small ms-auto" data-formbuilder--country-select-target="count"></span>
                        </div>
                        <div class="fb-country-list" data-formbuilder--country-select-target="list"
                             data-action="change->formbuilder--country-select#updateCount">
                            {{ form_widget(form.allowedShippingCountries) }}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Obavijesti (free) #}
        <div class="card mb-3 fb-card{{ isProduct ? ' d-none' : '' }}" data-formbuilder--formtype-target="free">
            <div class="card-body">
                <h2 class="h5 fb-section-title">{{ 'admin.form.builder.notify.title'|trans({}, 'admin') }}</h2>
                <p class="fb-section-help">{{ 'admin.form.builder.notify.help'|trans({}, 'admin') }}</p>
                {{ form_row(form.notifyEnabled) }}
                {{ form_row(form.notifyRecipient) }}
                {{ form_row(form.notifySubject) }}
            </div>
        </div>

        {# Polja forme — always #}
        <div class="card mb-3 fb-card">
            <div class="card-body">
                <h2 class="h5 fb-section-title">{{ 'admin.form.builder.fields.title'|trans({}, 'admin') }}</h2>
                <p class="fb-section-help">{{ 'admin.form.builder.fields.help'|trans({}, 'admin') }}</p>
                {{ form_errors(form.fields) }}

                {# datalist hint of existing field keys for the condition "field" inputs #}
                <datalist id="fb-field-keys">
                    {% for fieldForm in form.fields %}
                        <option value="{{ fieldForm.vars.value.key }}"></option>
                    {% endfor %}
                </datalist>

                {# The rules editor is JS-generated (contextual proxies): operator labels + placeholders.
                   Twig owns the translation and passes them all as one Stimulus value (labelsValue). #}
                <div data-fb-collection data-fb-level="fields" data-controller="formbuilder--rules"
                     data-formbuilder--rules-labels-value="{{ {
                         checked: 'admin.form.rule.op.checked'|trans({}, 'admin'),
                         not_checked: 'admin.form.rule.op.not_checked'|trans({}, 'admin'),
                         equals: 'admin.form.rule.op.equals'|trans({}, 'admin'),
                         not_equals: 'admin.form.rule.op.not_equals'|trans({}, 'admin'),
                         empty: 'admin.form.rule.op.empty'|trans({}, 'admin'),
                         not_empty: 'admin.form.rule.op.not_empty'|trans({}, 'admin'),
                         gt: 'admin.form.rule.op.gt'|trans({}, 'admin'),
                         lt: 'admin.form.rule.op.lt'|trans({}, 'admin'),
                         contains: 'admin.form.rule.op.contains'|trans({}, 'admin'),
                         field_ph: 'admin.form.rule.field_placeholder'|trans({}, 'admin'),
                         field_del: 'admin.form.rule.field_deleted'|trans({}, 'admin'),
                         no_opts: 'admin.form.rule.no_options'|trans({}, 'admin'),
                         value_ph: 'admin.form.rule.value_placeholder'|trans({}, 'admin')
                     }|json_encode|e('html_attr') }}"
                     data-prototype="{{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: form.fields.vars.prototype})|e('html_attr') }}"
                     data-prototype-name="__field__"
                     data-fb-index="{{ form.fields|length }}">
                    <div data-fb-items>
                        {% for fieldForm in form.fields %}
                            {{ include('@FormBuilder/admin/_field.html.twig', {fieldForm: fieldForm}) }}
                        {% endfor %}
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2" data-action="formbuilder--builder#add">{{ 'admin.form.builder.add_field'|trans({}, 'admin') }}</button>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">{{ 'admin.form.builder.save'|trans({}, 'admin') }}</button>
            <a class="btn btn-light" href="{{ path('form_builder_admin_index') }}">{{ 'admin.form.builder.cancel'|trans({}, 'admin') }}</a>
        </div>

        {# Every field is rendered manually above; emit only the CSRF token from the rest and disable
           form_rest so the fields collection isn't re-emitted as empty index-labelled fieldsets. #}
        {{ form_widget(form._token) }}
        {{ form_end(form, {render_rest: false}) }}
    </div>

    <style>
        /* Sections — softer cards + muted one-line help (EA/Bootstrap theme variables, dark-mode safe). */
        .fb-card { border-radius: 14px; }
        .fb-section-title { margin-bottom: .15rem; }
        .fb-section-help { color: var(--bs-secondary-color); font-size: .85rem; margin-bottom: 1rem; }
        .fb-badge-soft { background: var(--bs-primary-bg-subtle); color: var(--bs-primary-text-emphasis, var(--bs-primary)); font-weight: 500; font-size: .7rem; vertical-align: middle; }
        .fb-subblock { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--bs-border-color); }
        /* Ship-to countries: a scrollable, multi-column checkbox grid so ~250 items stay usable. */
        .fb-country-list { max-height: 16rem; overflow-y: auto; padding: .5rem .75rem; border: 1px solid var(--bs-border-color); border-radius: var(--bs-border-radius, .375rem); columns: 12rem auto; }
        .fb-country-list .form-check { break-inside: avoid; margin-bottom: .15rem; }

        /* Type toggle — two selectable cards (buttons; active state, no JS class churn needed). */
        .fb-type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .fb-type-option { display: flex; flex-direction: column; gap: .15rem; align-items: flex-start; text-align: left; padding: 1rem 1.1rem; border: 1px solid var(--bs-border-color); border-radius: 12px; cursor: pointer; background: var(--bs-body-bg); color: inherit; transition: border-color .15s, background .15s; }
        .fb-type-option[data-active] { border-color: var(--bs-primary); background: var(--bs-primary-bg-subtle); }
        .fb-type-title { font-weight: 600; }
        .fb-type-sub { color: var(--bs-secondary-color); font-size: .8rem; }

        /* Collection rows (field + variant) — theme variables fix the dark-mode "black box". */
        .fb-field-row { border: 1px solid var(--bs-border-color); border-radius: 12px; padding: 1rem; margin-bottom: 1rem; background: var(--bs-tertiary-bg); }
        .fb-row-head { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .5rem; }
        .fb-handle { color: var(--bs-secondary-color); cursor: grab; }
        .fb-handle:active { cursor: grabbing; }
        /* SortableJS placeholder while dragging a field row. */
        .fb-row-ghost { opacity: .5; background: var(--bs-primary-bg-subtle); }
        .fb-row-summary { display: flex; align-items: center; gap: .5rem; cursor: pointer; flex: 1; min-width: 0; }
        .fb-summary-label { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .fb-summary-required { font-size: .7rem; }
        .fb-row-controls { display: flex; gap: .25rem; flex-shrink: 0; }
        .fb-chevron::before { content: '▾'; color: var(--bs-secondary-color); font-size: .8rem; }
        .fb-field-row--collapsed .fb-chevron::before { content: '▸'; }
        .fb-field-row--collapsed .fb-row-head { margin-bottom: 0; }
        .fb-field-row--collapsed .fb-grid,
        .fb-field-row--collapsed .fb-cond { display: none; }
        .fb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem 1rem; }
        .fb-cond { margin-top: 1rem; border: 1px dashed var(--bs-border-color); border-radius: 8px; padding: .75rem; }
        .fb-cond legend { font-size: .85rem; color: var(--bs-secondary-color); width: auto; padding: 0 .4rem; }
        .fb-cond-head { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        /* Rule row: [field/operator/value block] + remove button. The block is either the real
           widgets (no-JS fallback) or the contextual proxy grid; both are a 3-col grid. */
        .fb-rule { display: grid; grid-template-columns: 1fr auto; gap: .5rem; align-items: start; margin-bottom: .5rem; }
        .fb-rule-real, .fb-rule-proxy-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .5rem; }
        .fb-rule .mb-3 { margin-bottom: 0 !important; }
        .fb-variant-row .mb-3 { margin-bottom: 0 !important; }
        .fb-cond-toggle { margin: .25rem 0 .5rem; }

        @media (max-width: 575px) {
            .fb-type-grid, .fb-grid, .fb-cond-head, .fb-rule-real, .fb-rule-proxy-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}
