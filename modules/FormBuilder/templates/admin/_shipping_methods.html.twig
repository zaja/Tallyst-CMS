{# Shipping-methods catalog editor (Postavke → Dostava). FormBuilder-owned, included by the Core
   settings template for the `shipping` section (loose Twig, like _payment_info). The row inputs bind
   to the separate <form id="settings-shipping"> (rendered at the bottom of settings.html.twig) via the
   HTML5 form= attribute, so no forms are nested — same pattern as the test-mail form. Add/remove reuse
   the generic formbuilder--builder controller; stable random per-row keys are generated server-side
   (ShippingCatalog) on save. #}
{% set methods = shipping_methods() %}
<hr>
<p class="text-muted small">{{ 'admin.settings.shipping.intro'|trans({}, 'admin') }}</p>

<div data-controller="formbuilder--builder">
    <div data-fb-collection data-fb-level="shipping"
         data-prototype="{{ include('@FormBuilder/admin/_shipping_row.html.twig', {index: '__ship__', method: {}})|e('html_attr') }}"
         data-prototype-name="__ship__"
         data-fb-index="{{ methods|length }}">
        <div data-fb-items>
            {% for method in methods %}
                {{ include('@FormBuilder/admin/_shipping_row.html.twig', {index: loop.index0, method: method}) }}
            {% endfor %}
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" data-action="formbuilder--builder#add">
            <i class="fa fa-plus"></i> {{ 'admin.settings.shipping.add'|trans({}, 'admin') }}
        </button>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit" form="settings-shipping">
            {{ 'admin.settings.shipping.save'|trans({}, 'admin') }}
        </button>
    </div>
</div>
