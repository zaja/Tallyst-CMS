{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Forme{% endblock %}

{% block page_actions %}
    <a class="btn btn-primary" href="{{ path('form_builder_admin_new') }}">+ Nova forma</a>
{% endblock %}

{% block main %}
    {% if forms is empty %}
        <div class="alert alert-light">
            Još nema formi. Kreirajte prvu pa je ubacite u stranicu shortcodeom <code>[form id=N]</code>.
        </div>
    {% else %}
        <table class="table table-hover">
            <thead>
                <tr><th>Naziv</th><th>Status</th><th>Shortcode</th><th>Polja</th><th class="text-end"></th></tr>
            </thead>
            <tbody>
                {% for f in forms %}
                    <tr>
                        <td><a href="{{ path('form_builder_admin_edit', {id: f.id}) }}">{{ f.name }}</a></td>
                        <td>
                            {% if f.published %}<span class="badge bg-success">Objavljeno</span>
                            {% else %}<span class="badge bg-secondary">Skica</span>{% endif %}
                        </td>
                        <td><code>[form id={{ f.id }}]</code></td>
                        <td>{{ f.fields|length }}</td>
                        <td class="text-end">
                            <form method="post" action="{{ path('form_builder_admin_delete', {id: f.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Obrisati formu?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_form_' ~ f.id) }}">
                                <button class="btn btn-sm btn-outline-danger" type="submit">Obriši</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
