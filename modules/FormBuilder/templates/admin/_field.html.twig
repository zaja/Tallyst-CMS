{# One field row. Used both for existing fields and as the collection prototype
   (fieldForm = form.fields.vars.prototype). The nested rules collection carries its
   own prototype + __rule__ placeholder.

   Collapsed by default (WP-Simple-Pay style): the head is a clickable summary
   (chevron + label + type badge) that toggles open; .fb-grid + .fb-cond are hidden when
   collapsed (CSS). A field that has a validation error renders EXPANDED so the error is
   visible after a failed save. The builder controller auto-expands a freshly ADDED field
   and keeps the summary (label + type badge) in sync as you type. #}
{% form_theme fieldForm 'bootstrap_5_layout.html.twig' %}
{% set fieldValue = fieldForm.vars.value %}
{% set fieldHasErrors = fieldForm.vars.errors|length > 0
    or fieldForm|filter(c => c.vars.errors|length > 0)|length > 0 %}
{% set typeValue = fieldValue ? fieldValue.type : null %}
{% set typeChoice = fieldForm.type.vars.choices|filter(c => c.value == typeValue)|first %}
{% set typeLabel = typeChoice ? typeChoice.label : '' %}
{% set summaryLabel = (fieldValue ? fieldValue.label : '') ?: 'Novo polje' %}
<div class="fb-field-row{% if not fieldHasErrors %} fb-field-row--collapsed{% endif %}" data-fb-item>
    <div class="fb-row-head">
        <div class="fb-row-summary" data-action="click->formbuilder--builder#toggle">
            <span class="fb-chevron"></span>
            <span class="fb-handle">≡</span>
            <span class="fb-summary-label" data-fb-summary-label>{{ summaryLabel }}</span>
            <span class="badge badge-secondary fb-summary-type" data-fb-summary-type>{{ typeLabel }}</span>
            {% if fieldValue and fieldValue.required %}<span class="badge badge-warning fb-summary-required">obavezno</span>{% endif %}
        </div>
        <div class="fb-row-controls">
            <button type="button" data-action="formbuilder--builder#moveUp" title="Gore">↑</button>
            <button type="button" data-action="formbuilder--builder#moveDown" title="Dolje">↓</button>
            <button type="button" class="fb-del" data-action="formbuilder--builder#remove">Ukloni polje</button>
        </div>
    </div>

    {{ form_widget(fieldForm.position, {attr: {'data-fb-position': ''}}) }}

    <div class="fb-grid">
        {{ form_row(fieldForm.label, {attr: {'data-fb-label-input': '', 'data-action': 'input->formbuilder--builder#refreshSummary'}}) }}
        {{ form_row(fieldForm.key) }}
        {{ form_row(fieldForm.type, {attr: {'data-fb-type-input': '', 'data-action': 'change->formbuilder--builder#refreshSummary'}}) }}
        {{ form_row(fieldForm.placeholder) }}
        {{ form_row(fieldForm.options) }}
        {{ form_row(fieldForm.required) }}
    </div>

    <fieldset class="fb-cond">
        <legend>Uvjeti prikaza (opcionalno)</legend>
        <div class="fb-cond-head">
            {{ form_row(fieldForm.conditions.action) }}
            {{ form_row(fieldForm.conditions.match) }}
        </div>

        <div data-fb-collection data-fb-level="rules"
             data-prototype="{{ include('@FormBuilder/admin/_rule.html.twig', {ruleForm: fieldForm.conditions.rules.vars.prototype})|e('html_attr') }}"
             data-prototype-name="__rule__"
             data-fb-index="{{ fieldForm.conditions.rules|length }}">
            <div data-fb-items>
                {% for ruleForm in fieldForm.conditions.rules %}
                    {{ include('@FormBuilder/admin/_rule.html.twig', {ruleForm: ruleForm}) }}
                {% endfor %}
            </div>
            <button type="button" class="fb-add-rule" data-action="formbuilder--builder#add">+ Pravilo</button>
        </div>
    </fieldset>
</div>
