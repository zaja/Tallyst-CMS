{# One shipping-method row: hidden stable key + name + price + remove. Plain-array inputs
   (methods[i][*]) bound to the separate settings-shipping form via the HTML5 form= attribute.
   Mirrors _variant_row's single-line layout, but this is NOT a Symfony collection — the catalog
   is a JSON setting edited outside the schema form. `method` is a {key,label,priceMinor} map (empty
   map for the prototype). Wired to the generic formbuilder--builder add/remove controller. #}
<div class="fb-field-row fb-variant-row mb-2" data-fb-item>
    <input type="hidden" name="methods[{{ index }}][key]" value="{{ method.key|default('') }}" form="settings-shipping">
    <div class="row g-2 align-items-end">
        <div class="col">
            <label class="form-label small mb-1">{{ 'admin.settings.shipping.method.name'|trans({}, 'admin') }}</label>
            <input type="text" class="form-control" name="methods[{{ index }}][label]"
                   value="{{ method.label|default('') }}" form="settings-shipping"
                   placeholder="{{ 'admin.settings.shipping.name_placeholder'|trans({}, 'admin') }}">
        </div>
        <div class="col-auto" style="max-width: 12rem;">
            <label class="form-label small mb-1">{{ 'admin.settings.shipping.method.price'|trans({}, 'admin') }}</label>
            <input type="number" step="0.01" min="0" class="form-control" name="methods[{{ index }}][price]"
                   value="{{ method.priceMinor is defined and method.priceMinor is not null ? (method.priceMinor / 100)|number_format(2, '.', '') : '' }}"
                   form="settings-shipping">
        </div>
        <div class="col-auto">
            <button type="button" class="btn btn-outline-danger" data-action="formbuilder--builder#remove"
                    title="{{ 'admin.settings.shipping.remove'|trans({}, 'admin') }}">&times;</button>
        </div>
    </div>
</div>
