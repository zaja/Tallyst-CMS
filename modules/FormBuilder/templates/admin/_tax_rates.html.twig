{# Tax editor (Postavke → Porez). FormBuilder-owned, included by the Core settings template for the `tax`
   section (loose Twig, like _shipping_methods). ONE "Save" persists BOTH the master toggle and the rate
   list: every input here binds to the separate <form id="settings-tax"> (rendered at the bottom of
   settings.html.twig) via the HTML5 form= attribute, so no forms are nested — the Core generic Save is
   auto-hidden (the tax section declares no scalar definitions). tax_enabled is the global MASTER switch;
   the rate list below it is the catalog. Add/remove reuse the generic formbuilder--builder controller;
   stable random per-row keys are generated server-side (TaxCatalog) on save. The "default" column is a
   shared radio group so exactly one rate is the default. #}
{% set rates = tax_rates() %}

{# Master switch — moved out of the scalar schema so it saves together with the rate list on one button.
   ⚠ This markup is rendered OUTSIDE Symfony Form / EA's form_theme (no ".form-widget" wrapper), so it
   doesn't get EA's own ".form-widget .form-check { padding:0 }" reset that every other admin checkbox/
   switch gets for free — Bootstrap's default ".form-switch { padding-left: 2.5em }" (reserved space for
   the switch track) is left standing, pushing the whole control ~2.5em right of the rest of the panel
   (the help text below, the "Name" labels elsewhere). Zeroed here explicitly (padding-left on the row +
   the matching negative margin-left Bootstrap would otherwise apply to the input) so the switch's left
   edge lines up with the surrounding content — switch-to-label spacing (label's own padding-inline-start)
   is untouched. #}
<div class="form-check form-switch mb-2" style="padding-left: 0;">
    <input type="checkbox" class="form-check-input" role="switch" id="tax_enabled"
           name="tax_enabled" value="1" form="settings-tax"{{ setting('tax_enabled') ? ' checked' : '' }}
           style="margin-left: 0;">
    <label class="form-check-label fw-semibold" for="tax_enabled">
        {{ 'admin.settings.tax.tax_enabled.label'|trans({}, 'admin') }}
    </label>
</div>
<p class="text-muted small">{{ 'admin.settings.tax.tax_enabled.help'|trans({}, 'admin') }}</p>

<hr>
<p class="text-muted small">{{ 'admin.settings.tax.intro'|trans({}, 'admin') }}</p>

<div data-controller="formbuilder--builder">
    <div data-fb-collection data-fb-level="tax"
         data-prototype="{{ include('@FormBuilder/admin/_tax_rate_row.html.twig', {index: '__tax__', rate: {}})|e('html_attr') }}"
         data-prototype-name="__tax__"
         data-fb-index="{{ rates|length }}">
        <div data-fb-items>
            {% for rate in rates %}
                {{ include('@FormBuilder/admin/_tax_rate_row.html.twig', {index: loop.index0, rate: rate}) }}
            {% endfor %}
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" data-action="formbuilder--builder#add">
            <i class="fa fa-plus"></i> {{ 'admin.settings.tax.add'|trans({}, 'admin') }}
        </button>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit" form="settings-tax">
            {{ 'admin.settings.tax.save'|trans({}, 'admin') }}
        </button>
    </div>
</div>
