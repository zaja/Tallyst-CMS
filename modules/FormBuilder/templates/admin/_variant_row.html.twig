{# One price-variant row: label + price + remove on a single line. [data-fb-item] + a remove button
   wired to the generic formbuilder--builder controller (same mechanism as field rows; no renumber).
   Inherits the themed .fb-field-row so it follows EA's light/dark theme. #}
<div class="fb-field-row fb-variant-row" data-fb-item>
    <div class="row g-2 align-items-end">
        <div class="col">{{ form_row(variantForm.label) }}</div>
        <div class="col-auto" style="max-width: 11rem;">{{ form_row(variantForm.priceMinor) }}</div>
        <div class="col-auto">
            <button type="button" class="btn btn-outline-danger" data-action="formbuilder--builder#remove" title="{{ 'admin.form.variant.remove'|trans({}, 'admin') }}">×</button>
        </div>
    </div>
</div>
