{# Readiness panel: on-demand webhook 401 self-test. FormBuilder owns the webhook routes, so this
   partial (button + probe controller) lives here and is included by templates/admin/readiness.html.twig
   (loose Twig coupling, like _payment_info). On-demand (button) so the HTTP self-test never slows the
   admin. #}
<div class="card mb-3" data-controller="formbuilder--webhook-check"
     data-formbuilder--webhook-check-url-value="{{ path('form_builder_admin_webhook_check') }}"
     data-formbuilder--webhook-check-csrf-value="{{ csrf_token('webhook_check') }}"
     {# JS-rendered status chrome — Twig owns the translation, JS reads these values (%status%/%error%
        are placeholders the controller substitutes). #}
     data-formbuilder--webhook-check-running-value="{{ 'admin.form.webhook_check.running'|trans({}, 'admin') }}"
     data-formbuilder--webhook-check-http-error-value="{{ 'admin.form.webhook_check.http_error'|trans({}, 'admin') }}"
     data-formbuilder--webhook-check-network-error-value="{{ 'admin.form.webhook_check.network_error'|trans({}, 'admin') }}"
     data-formbuilder--webhook-check-no-results-value="{{ 'admin.form.webhook_check.no_results'|trans({}, 'admin') }}">
    <div class="card-header">{{ 'admin.form.webhook_check.header'|trans({}, 'admin') }}</div>
    <div class="card-body">
        <p class="small text-muted mb-2">
            {{ 'admin.form.webhook_check.intro'|trans({}, 'admin') }}
        </p>
        <button type="button" class="btn btn-outline-primary btn-sm"
                data-formbuilder--webhook-check-target="button"
                data-action="formbuilder--webhook-check#run">{{ 'admin.form.webhook_check.button'|trans({}, 'admin') }}</button>
        <div class="mt-3" data-formbuilder--webhook-check-target="results"></div>
    </div>
</div>
