{# Per-provider info block for Postavke (included by the Core settings template per payment section).
   Params: provider (machine name), webhook_route (route name), dashboard (display name).
   Read-only: mode badge from the effective config + the webhook setup guide. #}
{% set mode = payment_mode(provider) %}
<hr>
<div class="mb-3">
    {% if mode == 'live' %}
        <span class="badge text-bg-success">LIVE MOD</span>
        <span class="text-muted small">— naplate idu uživo.</span>
    {% elseif mode == 'test' %}
        <span class="badge text-bg-warning">TEST MOD</span>
        <span class="text-muted small">— testni ključevi, nema stvarne naplate.</span>
    {% else %}
        <span class="badge text-bg-secondary">Nije konfigurirano</span>
        <span class="text-muted small">— upiši ključeve (ili postavi env varijable).</span>
    {% endif %}
</div>

<div class="card bg-body-tertiary">
    <div class="card-body">
        <h3 class="h6">Webhook postavljanje</h3>
        <p class="small mb-1">Webhook URL (zalijepi u {{ dashboard }}):</p>
        <input type="text" class="form-control form-control-sm mb-2" readonly
               value="{{ url(webhook_route) }}"
               onclick="this.select()">
        <p class="small mb-1">Obavezni eventi:</p>
        <ul class="small mb-2">
            {% for event in payment_webhook_events(provider) %}
                <li><code>{{ event }}</code></li>
            {% endfor %}
        </ul>
        <p class="small text-muted mb-0">
            {{ dashboard }} dashboard → Webhooks → <strong>Add endpoint</strong> → zalijepi URL →
            odaberi evente. <strong>Test/sandbox i live imaju ODVOJENE endpointe</strong> (svaki sa
            svojim ključevima/secretom).
        </p>
    </div>
</div>
