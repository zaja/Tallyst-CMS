{# Stripe info block shown in Postavke → Stripe (included by the Core settings template for the
   'stripe' section). Read-only: mode badge from the effective key + the webhook setup guide. #}
{% set mode = stripe_mode() %}
<hr>
<div class="mb-3">
    {% if mode == 'live' %}
        <span class="badge text-bg-success">LIVE MOD</span>
        <span class="text-muted small">— naplate idu uživo.</span>
    {% elseif mode == 'test' %}
        <span class="badge text-bg-warning">TEST MOD</span>
        <span class="text-muted small">— testni ključevi, nema stvarne naplate.</span>
    {% else %}
        <span class="badge text-bg-secondary">Nije konfigurirano</span>
        <span class="text-muted small">— upiši tajni ključ (ili postavi STRIPE_SECRET_KEY).</span>
    {% endif %}
</div>

<div class="card bg-body-tertiary">
    <div class="card-body">
        <h3 class="h6">Webhook postavljanje</h3>
        <p class="small mb-1">Webhook URL (zalijepi u Stripe):</p>
        <input type="text" class="form-control form-control-sm mb-2" readonly
               value="{{ url('form_builder_webhook_stripe') }}"
               onclick="this.select()">
        <p class="small mb-1">Obavezni eventi:</p>
        <ul class="small mb-2">
            {% for event in stripe_webhook_events() %}
                <li><code>{{ event }}</code></li>
            {% endfor %}
        </ul>
        <p class="small text-muted mb-0">
            Stripe dashboard → Developers → Webhooks → <strong>Add endpoint</strong> → zalijepi URL →
            odaberi evente. <strong>Test i live imaju ODVOJENE endpointe</strong> (svaki sa svojim
            webhook secretom).
        </p>
    </div>
</div>
