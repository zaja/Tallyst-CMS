{% extends 'layout.html.twig' %}

{% block title %}{{ 'form.thankyou.page_title'|trans({'%id%': order.id}) }}{% endblock %}

{% block body %}
    {% set order_ref %}<strong>#{{ order.id }}</strong>{% endset %}
    <article class="fb-thankyou">
        <h1>{{ 'form.thankyou.title'|trans }}</h1>

        {# Admin-editable copy (Postavke → Narudžbe); the SettingDefinition default applies when unset. #}
        <div class="fb-thankyou-message">{{ setting('thank_you_message')|render_content }}</div>

        {% if order.paid %}
            <p>{{ 'form.thankyou.paid'|trans({'%order%': order_ref})|raw }}</p>
        {% else %}
            <p>{{ 'form.thankyou.processing'|trans({'%order%': order_ref})|raw }}</p>
        {% endif %}

        <p>
            {{ 'form.thankyou.amount'|trans }}
            <strong>{{ (order.amountMinor / 100)|number_format(2, ',', '.') }} {{ order.currency|upper }}</strong>
        </p>

        <p><a href="{{ path('home') }}">{{ icon('arrow-left') }} {{ 'form.thankyou.back_home'|trans }}</a></p>
    </article>

    {# Minimal decent styling (was unstyled) — theme tokens with neutral fallbacks. #}
    <style>
        .fb-thankyou { max-width: 40rem; margin-inline: auto; padding: var(--s-7, 3rem) 0; text-align: center; }
        .fb-thankyou-message { font-size: var(--fs-lg, 1.1875rem); color: var(--muted, #5f6b78); margin-bottom: 1.5rem; }
        .fb-thankyou-message > :first-child { margin-top: 0; }
    </style>
{% endblock %}
