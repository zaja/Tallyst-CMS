{# Data-driven end-user form. NOT the Symfony Form component (see CLAUDE.md rule 3).
   The Stimulus controller reads the embedded schema and shows/hides fields live;
   the server re-validates the same rules. #}
{% set submitted = app.request.query.get('fb_success') == form.id %}

<div class="fb-form-wrap">
    {% if submitted %}
        <div class="fb-success" role="status">{{ 'form.success'|trans }}</div>
    {% endif %}

    {# data-turbo="false": the submit may 303-redirect to an external payment page
       (Stripe Checkout); Turbo can't follow a cross-origin redirect, so use a normal
       full-page navigation. Stimulus (conditional logic) is unaffected. #}
    <form class="fb-form" method="post"
          action="{{ path('form_builder_submit', {id: form.id}) }}"
          data-turbo="false"
          data-controller="formbuilder--conditions"
          data-formbuilder--conditions-schema-value="{{ schema|json_encode|e('html_attr') }}">

        <input type="hidden" name="_token" value="{{ csrf_token('form_submit_' ~ form.id) }}">
        <input type="hidden" name="_return" value="{{ app.request.requestUri }}">

        {# Honeypot: hidden from humans; bots that fill it are silently dropped. #}
        <div class="fb-hp" aria-hidden="true">
            <label>{{ 'form.honeypot'|trans }}
                <input type="text" name="_hp" tabindex="-1" autocomplete="off">
            </label>
        </div>

        {% if form.priceMinor and not form.hasVariants %}
            <p class="fb-price">{{ 'form.price'|trans }} <strong>{{ (form.priceMinor / 100)|number_format(2, ',', '.') }} {{ (form.currency ?: 'eur')|upper }}</strong></p>
        {% endif %}

        {% if tax.enabled|default(false) and form.isProduct %}
            <p class="fb-tax">{{ 'form.tax_note'|trans({'%name%': tax.name, '%rate%': tax.rate}) }}</p>
        {% endif %}

        {% if form.description %}<p class="fb-desc">{{ form.description }}</p>{% endif %}

        {% for field in form.fields %}
            {% set key = field.key %}
            {% set val = old[key] is defined ? old[key] : '' %}
            {% set err = errors[key] is defined ? errors[key] : null %}
            {% set fid = 'fb-' ~ form.id ~ '-' ~ key %}

            <div class="fb-field"
                 data-formbuilder--conditions-target="field"
                 data-field-key="{{ key }}">

                {% if field.type != 'checkbox' %}
                    <label for="{{ fid }}">{{ field.label }}{% if field.required %} <span class="fb-req">*</span>{% endif %}</label>
                {% endif %}

                {% if field.type == 'textarea' %}
                    <textarea id="{{ fid }}" name="{{ key }}"{% if field.required %} required{% endif %}
                              placeholder="{{ field.placeholder }}">{{ val }}</textarea>

                {% elseif field.type == 'select' %}
                    <select id="{{ fid }}" name="{{ key }}"{% if field.required %} required{% endif %}>
                        <option value="">—</option>
                        {% for opt in field.options %}
                            <option value="{{ opt }}"{{ val == opt ? ' selected' : '' }}>{{ opt }}</option>
                        {% endfor %}
                    </select>

                {% elseif field.type == 'radio' %}
                    <div class="fb-choices">
                        {% for opt in field.options %}
                            <label class="fb-choice">
                                <input type="radio" name="{{ key }}" value="{{ opt }}"{{ val == opt ? ' checked' : '' }}{% if field.required %} required{% endif %}>
                                {{ opt }}
                            </label>
                        {% endfor %}
                    </div>

                {% elseif field.type == 'checkbox' %}
                    <label class="fb-choice">
                        <input type="checkbox" id="{{ fid }}" name="{{ key }}" value="1"{{ val ? ' checked' : '' }}{% if field.required %} required{% endif %}>
                        {{ field.label }}{% if field.required %} <span class="fb-req">*</span>{% endif %}
                    </label>

                {% else %}
                    {% set inputType = field.type == 'number' ? 'number' : (field.type == 'email' ? 'email' : 'text') %}
                    <input type="{{ inputType }}" id="{{ fid }}" name="{{ key }}" value="{{ val }}"{% if field.required %} required{% endif %}
                           placeholder="{{ field.placeholder }}">
                {% endif %}

                {% if err %}<p class="fb-error">{{ err }}</p>{% endif %}
            </div>
        {% endfor %}

        {% if form.isProduct %}
            {% set methods = payment_methods|default([]) %}
            {% if methods is empty %}
                <p class="fb-error">{{ 'form.payment_unavailable'|trans }}</p>
            {% else %}
                {% if form.hasVariants %}
                    <div class="fb-field fb-variants">
                        <label>{{ 'form.choose_option'|trans }} <span class="fb-req">*</span></label>
                        <div class="fb-choices">
                            {% for v in form.variants %}
                                <label class="fb-choice">
                                    <input type="radio" name="variant" value="{{ loop.index0 }}"{{ loop.first ? ' checked' : '' }} required>
                                    {{ v.label }} — {{ (v.priceMinor / 100)|number_format(2, ',', '.') }} {{ (form.currency ?: 'eur')|upper }}
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Shipping (Faza 1): radios when >1 offered, hidden index 0 when exactly one; the server
                   resolves the choice by INDEX against the same offered list and reads the price from the
                   catalog (never this markup). Not rendered on MoR forms (shipping is empty there). #}
                {% if shipping|default([]) is not empty %}
                    {% if shipping|length > 1 %}
                        <div class="fb-field fb-shipping">
                            <label>{{ 'form.choose_shipping'|trans }} <span class="fb-req">*</span></label>
                            <div class="fb-choices">
                                {% for m in shipping %}
                                    <label class="fb-choice">
                                        <input type="radio" name="shipping" value="{{ loop.index0 }}"{{ loop.first ? ' checked' : '' }} required>
                                        {{ m.label }} — {{ (m.priceMinor / 100)|number_format(2, ',', '.') }} {{ currency }}
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <input type="hidden" name="shipping" value="0">
                        <p class="fb-shipping-single">{{ 'form.shipping'|trans }}: <strong>{{ shipping[0].label }} — {{ (shipping[0].priceMinor / 100)|number_format(2, ',', '.') }} {{ currency }}</strong></p>
                    {% endif %}

                    {# Delivery address: required whenever delivery is offered (derived, no flag). Values are
                       saved into the submission data under the ship_* keys. #}
                    <div class="fb-address">
                        {% for key, labelKey in shipping_address %}
                            {% set aval = old[key] is defined ? old[key] : '' %}
                            {% set aerr = errors[key] is defined ? errors[key] : null %}
                            <div class="fb-field">
                                <label for="fb-{{ form.id }}-{{ key }}">{{ labelKey|trans }} <span class="fb-req">*</span></label>
                                {% if key == 'ship_country' %}
                                    {# Country (Faza 2): a dropdown limited to the form's allowed countries (or
                                       the full list when unrestricted). The server re-validates the chosen code. #}
                                    <select id="fb-{{ form.id }}-{{ key }}" name="{{ key }}" required>
                                        <option value="">—</option>
                                        {% for code, name in shipping_countries %}
                                            <option value="{{ code }}"{{ aval == code ? ' selected' : '' }}>{{ name }}</option>
                                        {% endfor %}
                                    </select>
                                {% else %}
                                    <input type="text" id="fb-{{ form.id }}-{{ key }}" name="{{ key }}" value="{{ aval }}" required>
                                {% endif %}
                                {% if aerr %}<p class="fb-error">{{ aerr }}</p>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if methods|length > 1 %}
                    <div class="fb-field fb-payment">
                        <label>{{ 'form.payment_method'|trans }} <span class="fb-req">*</span></label>
                        <div class="fb-choices">
                            {% for m in methods %}
                                <label class="fb-choice">
                                    <input type="radio" name="payment_method" value="{{ m.name }}"{{ loop.first ? ' checked' : '' }} required>
                                    {{ m.label }}
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <input type="hidden" name="payment_method" value="{{ methods[0].name }}">
                {% endif %}
                <button type="submit" class="fb-submit">{{ 'form.checkout'|trans }}</button>
            {% endif %}
        {% else %}
            <button type="submit" class="fb-submit">{{ 'form.submit'|trans }}</button>
        {% endif %}
    </form>
</div>

{# Brand/line/radius come from the THEME tokens (CSS custom properties are global on the front),
   with neutral fallbacks for a theme that defines none. Error/success stay semantic (red/green). #}
<style>
    .fb-form-wrap { margin: 1.5rem 0; }
    .fb-form { display: grid; gap: 1rem; max-width: 32rem; }
    .fb-field label { display: block; font-weight: 600; margin-bottom: .25rem; }
    .fb-field input[type=text], .fb-field input[type=email], .fb-field input[type=number],
    .fb-field select, .fb-field textarea { width: 100%; padding: .55rem .65rem; border: 1px solid var(--line, #d1d5db); border-radius: var(--radius-sm, 8px); font: inherit; }
    .fb-field textarea { min-height: 6rem; }
    .fb-choice { display: block; font-weight: 400; }
    .fb-req { color: #dc2626; }
    .fb-error { color: #b91c1c; font-size: .85rem; margin: .35rem 0 0; }
    .fb-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; padding: .7rem .9rem; border-radius: var(--radius-sm, 8px); margin-bottom: 1rem; }
    .fb-submit { justify-self: start; background: var(--brand, #2563eb); color: var(--brand-ink, #fff); border: 0; border-radius: var(--radius-sm, 8px); padding: .6rem 1.1rem; font: inherit; cursor: pointer; }
    .fb-submit:hover { background: var(--brand-strong, #1d4ed8); }
    .fb-field[hidden] { display: none; }
    .fb-hp { position: absolute !important; left: -9999px !important; top: -9999px !important; height: 0; width: 0; overflow: hidden; }
    .fb-price { font-size: 1.05rem; }
</style>
