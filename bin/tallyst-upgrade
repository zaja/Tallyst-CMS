#!/usr/bin/env bash
#
# tallyst-upgrade — one-command upgrade over the supported git-checkout path.
#
# Usage:  bin/tallyst-upgrade [vX.Y.Z] [-- finalize-options]
#   bin/tallyst-upgrade            # upgrade to the latest tag
#   bin/tallyst-upgrade v1.5.1     # upgrade to a specific tag
#   bin/tallyst-upgrade v1.5.1 --no-backup   # extra args go to app:upgrade:finalize
#
# Server-agnostic: detects PHP >= 8.5 and Composer (no hardcoded php8.5 / composer path).
# Safe (no PHP self-modify): each step is a SEPARATE process — git swaps the code atomically,
# then a FRESH Composer and a FRESH php read the NEW code. It does NOT restart the messenger
# worker (an ops step — app:upgrade:finalize prints the exact command at the end).
#
# Tallyst is installed + updated ONLY via git clone (see docs/INSTALL.md), so .git is always
# present and the checkout is a plain checkout that surfaces conflicts if you edited core.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=bin/_tallyst-lib.sh
. "$SCRIPT_DIR/_tallyst-lib.sh"
cd "$SCRIPT_DIR/.."

# Upgrade in the PRODUCTION environment (same reason as install): we run `composer install
# --no-dev`, so its post-install `cache:clear` must boot the PROD kernel. A normal prod install
# already has APP_ENV=prod in .env.local, but a real env var makes it robust even on a dev
# instance and keeps setup/upgrade consistent. finalize's own subprocesses strip APP_ENV and
# re-read .env.local, so this doesn't disturb them. Shell-local: does not leak past the script.
export APP_ENV=prod

require_git

# A git checkout is the ONLY supported install/update mechanism. No .git → stop with a clear
# message (no auto-bridge, no create-project fallback — install via git clone).
if [ ! -d .git ]; then
    echo "Error: this is not a git checkout (no .git directory)." >&2
    echo "Tallyst must be installed via 'git clone' — see docs/INSTALL.md." >&2
    exit 1
fi

detect_php
detect_composer
echo "==> Using PHP: $PHP    Composer: $COMPOSER"

# 1) Fetch tags/branches so 'latest' and the target tag are known.
echo "==> Fetching…"
git fetch --tags origin

# 2) Resolve the target tag (arg wins; otherwise the newest tag on origin/main).
TAG="${1:-}"
if [ -z "$TAG" ]; then
    TAG="$(git describe --tags --abbrev=0 origin/main)"
    echo "==> No version given — using the latest: $TAG"
fi

# 3) Code swap (atomic; a plain checkout REPORTS a conflict if you edited core files).
#    -c advice.detachedHead=false suppresses git's long "detached HEAD" notice (normal for a tag
#    checkout; inline so it doesn't persist in .git/config). We already print the tag above.
echo "==> Checking out $TAG…"
if ! git -c advice.detachedHead=false checkout "$TAG"; then
    echo "Error: checkout failed — you likely have local changes to core files." >&2
    echo "Commit or stash them, or discard with 'git checkout -- .', then retry." >&2
    exit 1
fi

# 4) Dependencies (deterministic from the lock file; the only step that touches vendor/).
echo "==> Installing dependencies…"
# Word-split $COMPOSER on purpose (it may be "php composer.phar").
# shellcheck disable=SC2086
$COMPOSER install --no-interaction --no-dev --optimize-autoloader

# 5) Finalize: backup -> cache:clear -> migrate -> assets -> cache (fresh kernel each).
#    Pass through any extra args after the tag (e.g. --no-backup).
echo "==> Finalizing upgrade…"
"$PHP" bin/console app:upgrade:finalize "${@:2}"
