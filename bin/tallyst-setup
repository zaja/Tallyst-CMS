#!/usr/bin/env bash
#
# tallyst-setup — first-run install bootstrap (run once, right after `git clone`).
#
# Usage:  bin/tallyst-setup
#
# It hides the server specifics: detects a PHP >= 8.5 binary and a Composer command (no hardcoded
# php8.5 / composer path), installs the production dependencies, then hands off to the interactive
# `app:install` wizard (database, admin account, .env.local). Override the probes with PHP=… or
# COMPOSER=… if your host is unusual.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=bin/_tallyst-lib.sh
. "$SCRIPT_DIR/_tallyst-lib.sh"
cd "$SCRIPT_DIR/.."

# Install in the PRODUCTION environment. We install prod-only dependencies (--no-dev), so
# Composer's post-install `cache:clear` must boot the PROD kernel — the default `dev` kernel
# (no .env.local yet → .env's APP_ENV=dev) would try to load dev-only bundles (DebugBundle,
# WebProfiler, Maker) that --no-dev left out, and fail. app:install then persists APP_ENV=prod
# into .env.local. Shell-local: this does not leak past the script.
export APP_ENV=prod

detect_php
detect_composer
echo "==> Using PHP: $PHP    Composer: $COMPOSER"

# --no-scripts: skip Symfony Flex's implicit post-install cache:clear/assets:install/
# importmap:install (@auto-scripts) — .env.local doesn't exist yet at this point (app:install
# writes it next), and app:install's own "Asset fallback" section below already runs
# importmap:install + asset-map:compile + app:theme:assets:install + cache:clear itself, with
# loud failure surfacing. Symmetric with bin/tallyst-upgrade (see its comment for the upgrade-
# side crash this avoids: a stale prod container loaded against just-checked-out new code).
echo "==> Installing dependencies…"
# Word-split $COMPOSER on purpose (it may be "php composer.phar").
# shellcheck disable=SC2086
$COMPOSER install --no-interaction --no-dev --optimize-autoloader --no-scripts

echo "==> Starting the interactive installer…"
"$PHP" bin/console app:install
