{# App override of the EA admin layout: (1) a global "maintenance mode active" reminder on EVERY admin
   page; (2) a tiny global i18n object for BOOTSTRAP-wired editor JS that can't read a per-page Twig
   element (the "Insert form" button + form-picker modal — see CLAUDE.md / form_picker.js);
   (3) a discreet core-version line at the bottom of the sidebar (support/troubleshooting). #}
{% extends '@!EasyAdmin/layout.html.twig' %}

{% block flash_messages %}
    {# Inline (non-module) script: runs during HTML parse, BEFORE the deferred importmap module
       (stimulus_bootstrap.js) executes — so the global is set in time for registerEditorExtension.
       Carries ONLY the form-picker strings; extend this object if more bootstrap-JS strings appear,
       do NOT grow a general i18n runtime. #}
    <script>
        window.__tallystI18n = {
            formPicker: {
                insert: {{ 'admin.form.picker.insert'|trans({}, 'admin')|json_encode|raw }},
                title: {{ 'admin.form.picker.title'|trans({}, 'admin')|json_encode|raw }},
                close: {{ 'admin.form.picker.close'|trans({}, 'admin')|json_encode|raw }},
                loading: {{ 'admin.form.picker.loading'|trans({}, 'admin')|json_encode|raw }},
                load_error: {{ 'admin.form.picker.load_error'|trans({}, 'admin')|json_encode|raw }},
                none: {{ 'admin.form.picker.none'|trans({}, 'admin')|json_encode|raw }},
                draft: {{ 'admin.form.picker.draft'|trans({}, 'admin')|json_encode|raw }}
            },
            dirtyGuard: {{ 'admin.js.dirty_guard'|trans({}, 'admin')|json_encode|raw }},
            filePond: {
                idle: {{ 'admin.js.filepond.idle'|trans({}, 'admin')|json_encode|raw }},
                type_not_allowed: {{ 'admin.js.filepond.type_not_allowed'|trans({}, 'admin')|json_encode|raw }},
                too_big: {{ 'admin.js.filepond.too_big'|trans({}, 'admin')|json_encode|raw }},
                max_size: {{ 'admin.js.filepond.max_size'|trans({}, 'admin')|json_encode|raw }}
            }
        };
    </script>

    {% if setting('maintenance_enabled') %}
        <div class="alert alert-warning m-3 mb-0" role="alert">
            ⚠ <strong>{{ 'admin.maintenance_banner.title'|trans({}, 'admin') }}</strong> {{ 'admin.maintenance_banner.note'|trans({}, 'admin') }}
            <a href="{{ path('admin_settings') }}" class="alert-link">{{ 'admin.maintenance_banner.link'|trans({}, 'admin') }}</a>
        </div>
    {% endif %}
    {{ parent() }}
{% endblock %}

{# Discreet "Tallyst v1.1.0" pinned to the BOTTOM of the sidebar (under the menu). Version is read
   from Composer metadata via VersionProvider (no hardcoding); falls back to "(dev)" on a git clone.
   The EA `.wrapper` is a grid with min-block-size:100vh, so `.sidebar-wrapper` is full-height; making
   `.sidebar` a full-height flex column lets `mt-auto` push the version to the very bottom. #}
{% block sidebar %}
    <style>
        .sidebar-wrapper > .sidebar { display: flex; flex-direction: column; min-block-size: 100%; }
        /* Collapsible SYSTEM section (admin--menu-collapse): hide its items when collapsed. */
        .menu-item.menu-section-collapsed { display: none !important; }
        /* Lay the SYSTEM header out as one row (EA defaults menu-header-contents to display:block),
           so the caret sits INLINE with the label and never wraps onto a second line. Scoped to the
           SYSTEM section via :has so other section headers are untouched. */
        #main-menu .menu .menu-header:has(.js-tallyst-system) .menu-header-contents {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        /* A clear, bold +/− toggle indicator (the JS appends a '▾' glyph which we hide via
           font-size:0 and replace with ::before, so the collapse JS stays untouched). + when
           collapsed, − when expanded — far more legible than a faint caret. */
        .menu-collapse-caret {
            margin-inline-start: auto;
            flex: 0 0 auto;
            font-size: 0; /* hide the JS '▾' glyph; ::before carries the visible indicator */
            line-height: 1;
        }
        .menu-collapse-caret::before {
            content: '+';
            font-size: 1.25rem;
            font-weight: 700;
            line-height: 1;
            opacity: 1;
        }
        .menu-header-contents[aria-expanded="true"] .menu-collapse-caret::before {
            content: '\2212'; /* − minus sign (U+2212) when expanded */
        }
        /* ⚠ EA BUG FIX — small text buttons had 0 horizontal padding. EA ships
           `.btn-sm:not(:has(.btn-label)){padding:var(--button-padding-y-sm)}` — a SHORTHAND
           `padding` with a Y-ONLY value (0px, since sm buttons get their height from
           min-block-size) → it zeros ALL FOUR sides, so a small button WITHOUT a .btn-label
           child (our plain-text CTAs: demo, media-picker, form-builder…) has no left/right
           padding and the text touches the edge. Same selector (identical specificity) but
           declared here, later in the cascade, so it wins; `padding-inline` restores ONLY the
           horizontal padding and leaves the 0 vertical (height stays from min-block-size).
           10px = EA's sm token (8px) + a touch of air, without matching the 12px full buttons.
           Only DevTools (Computed) catches this — a static grep misses it (var, not literal 0). */
        .btn-sm:not(:has(.btn-label)) { padding-inline: 10px; }
        /* Row-action icons (Edit/Preview/Delete) sat far apart. Measured via the compiled EA CSS
           (vendor/easycorp/easyadmin-bundle/public/app.*.css), not guessed: each ghost button keeps
           EA's full "md" horizontal padding (--button-padding-x, falls back to the root
           --button-padding-x-md: 12px) even icon-only, AND EA separately adds
           `margin-inline-start:10px` between two consecutive row-action <a>s and around the delete
           <form> (`.datagrid td.actions a:not(.dropdown-item)+a:not(.dropdown-item)` /
           `…:not(.actions-as-dropdown) form`) — so two adjacent icons end up ~34px apart
           (12 + 10 + 12). It's a COMBINATION, not either alone. Fix tightens both, scoped to
           row-action buttons only — `.btn-invisible` + `.action-edit`/`-delete`/`-preview` is used
           ONLY by list-row actions (EA-native lists via AdminCrudPolishTrait + the two hand-mirrored
           custom lists, Forms/E-mail templates) — never touches labelled buttons (Save/Back/+ New)
           or interacts with the .btn-sm fix above (different selector, different buttons). Sets
           `--button-padding-x` directly (not the root `-md` fallback), so only these buttons shrink,
           not every button on the page. The two margin rules reuse EA's own selectors verbatim so
           the identical-specificity/later-in-cascade rule (same pattern as the .btn-sm fix) applies
           cleanly; they're no-ops on the custom lists (no .datagrid ancestor there), where the
           tightened button padding alone is enough. */
        .action-edit.btn-invisible,
        .action-delete.btn-invisible,
        .action-preview.btn-invisible {
            --button-padding-x: 6px;
        }
        .datagrid td.actions a:not(.dropdown-item)+a:not(.dropdown-item) {
            margin-inline-start: 4px;
        }
        .datagrid td.actions:not(.actions-as-dropdown) form {
            margin-inline-start: 4px;
            margin-inline-end: 4px;
        }
        /* Posts-list thumbnail column (admin/post/thumb.html.twig). media_img() emits a bare
           <img class="media-img">, unstyled here since the admin never loads the front theme
           CSS (no --button-* token conflict; .media-img has no admin-side rule otherwise).
           Narrower than Media's own list thumb (120×64) — this column was squeezing the rest
           of the Posts table (Author wrapping to two lines); object-fit:cover keeps the crop
           sane at the smaller size. */
        .post-thumb img {
            max-height: 56px;
            max-width: 72px;
            border-radius: 4px;
            object-fit: cover;
        }
        /* Page edit "Hero section" fieldset — chevron↔title gap was too wide. Measured from the
           compiled EA CSS: the collapse chevron carries `margin: 0 10px 0 2px` (10px trailing)
           AND the fieldset's own custom icon (panorama) carries `margin-inline-end: 10px` — the
           two stack because Hero is the only addFieldset() in the app that pairs a collapsible
           chevron with a `.setIcon()`, so nobody hit this before. Scoped to `.page-hero-fieldset`
           (set via addCssClass in PageCrudController) — doesn't touch chevrons/icons on any other
           (currently nonexistent) collapsible fieldset. */
        .page-hero-fieldset .form-fieldset-collapse-marker {
            margin-inline-end: 4px;
        }
        /* EA's own rule is `.form-fieldset-header .form-fieldset-title .form-fieldset-icon`
           (3 classes) — this override MUST match that specificity (3 classes) or it silently
           loses regardless of cascade order. */
        .page-hero-fieldset .form-fieldset-title .form-fieldset-icon {
            margin-inline-end: 6px;
        }
        /* Keep row-action icons (Edit/Preview/Delete) on ONE line — a wide column elsewhere in
           the row (e.g. the Posts thumbnail) can squeeze the actions cell narrow enough that the
           browser wraps the icons onto a second line. table-layout stays "auto" (unchanged), so
           nowrap just lets this cell claim the width it needs instead of wrapping.
           `.datagrid td.actions` covers every EA-native CRUD list (AdminCrudPolishTrait).
           `td.text-end:has(.btn-invisible)` covers the two hand-built lists (Forms, E-mail
           templates) — scoped to actual action cells only (via the btn-invisible signal), not
           every `.text-end` cell in the admin (settings/other tables use that class too). */
        .datagrid td.actions,
        td.text-end:has(.btn-invisible) {
            white-space: nowrap;
        }
    </style>
    {{ parent() }}
    <div class="tallyst-version text-muted small px-3 py-2 mt-auto" style="opacity: .65;">
        Tallyst {{ tallyst_version().coreVersion }}
    </div>
{% endblock %}

{# Wrap ONLY the menu nav (not the header or version footer) so the collapse controller is scoped
   to the sidebar menu. The SYSTEM section is marked with .js-tallyst-system (DashboardController). #}
{% block main_menu_wrapper %}
    {# display:contents keeps the EA sidebar flex layout identical (the nav stays a direct flex child,
       so the version footer's mt-auto is unaffected); the controller still scopes to its descendants. #}
    <div data-controller="admin--menu-collapse"
         data-admin--menu-collapse-section-class-value="js-tallyst-system"
         data-admin--menu-collapse-storage-key-value="tallyst.menu.system"
         data-admin--menu-collapse-aria-label-value="{{ 'admin.menu.toggle_section'|trans({}, 'admin') }}"
         style="display: contents;">
        {{ parent() }}
    </div>
{% endblock %}
