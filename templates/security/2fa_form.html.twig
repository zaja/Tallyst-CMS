<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dvostruka provjera — Tallyst Admin</title>
    {# Standalone page styled like templates/security/login.html.twig. #}
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f3f4f6; color: #1a1a1a; margin: 0; display: flex; min-height: 100vh; align-items: center; justify-content: center; }
        .card { background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.1); width: 100%; max-width: 360px; }
        h1 { font-size: 1.25rem; margin: 0 0 1.25rem; }
        label { display: block; font-size: .85rem; margin: .75rem 0 .25rem; color: #444; }
        input[type=text] { width: 100%; padding: .6rem .7rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1.25rem; letter-spacing: .2em; text-align: center; }
        button { width: 100%; margin-top: 1.25rem; padding: .65rem; border: 0; border-radius: 8px; background: #2563eb; color: #fff; font-size: 1rem; cursor: pointer; }
        button:hover { background: #1d4ed8; }
        .error { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; padding: .6rem .7rem; border-radius: 8px; font-size: .9rem; margin-bottom: 1rem; }
        .muted { color: #666; font-size: .9rem; margin: .75rem 0 0; }
        a { color: #2563eb; text-decoration: none; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <form class="card" action="{{ checkPathUrl ? checkPathUrl : path(checkPathRoute) }}" method="post">
        <h1>Dvostruka provjera</h1>

        {% if authenticationError %}
            <div class="error">{{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}</div>
        {% endif %}

        <label for="_auth_code">Kod iz aplikacije (ili backup kod)</label>
        <input id="_auth_code" type="text" name="{{ authCodeParameterName }}" autocomplete="one-time-code"
               inputmode="numeric" autofocus>

        {% if isCsrfProtectionEnabled %}
            <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
        {% endif %}

        <button type="submit">Potvrdi</button>

        <p class="muted"><a href="{{ logoutPath }}">Odustani (odjava)</a></p>
    </form>
</body>
</html>
