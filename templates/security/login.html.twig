<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'security.login.title'|trans }}</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f3f4f6; color: #1a1a1a; margin: 0; display: flex; min-height: 100vh; align-items: center; justify-content: center; }
        .card { background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.1); width: 100%; max-width: 360px; }
        h1 { font-size: 1.25rem; margin: 0 0 1.25rem; }
        label { display: block; font-size: .85rem; margin: .75rem 0 .25rem; color: #444; }
        input[type=email], input[type=password] { width: 100%; padding: .6rem .7rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; }
        button { width: 100%; margin-top: 1.25rem; padding: .65rem; border: 0; border-radius: 8px; background: #2563eb; color: #fff; font-size: 1rem; cursor: pointer; }
        button:hover { background: #1d4ed8; }
        .error { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; padding: .6rem .7rem; border-radius: 8px; font-size: .9rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <form class="card" method="post" action="{{ path('admin_login') }}">
        <h1>Tallyst Admin</h1>

        {% if error %}
            <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <label for="username">{{ 'field.email'|trans }}</label>
        <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="username" required autofocus>

        <label for="password">{{ 'field.password'|trans }}</label>
        <input type="password" id="password" name="_password" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">{{ 'security.login.submit'|trans }}</button>

        <p style="text-align: center; margin: 1rem 0 0; font-size: .9rem;">
            <a href="{{ path('app_forgot_password_request') }}" style="color: #2563eb; text-decoration: none;">{{ 'security.login.forgot'|trans }}</a>
        </p>
    </form>
</body>
</html>
