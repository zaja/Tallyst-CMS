{% extends 'reset_password/_layout.html.twig' %}

{% block title %}{{ 'reset.check.title'|trans }} — Tallyst{% endblock %}

{% block body %}
    <h1>{{ 'reset.check.title'|trans }}</h1>
    <p class="muted">
        {{ 'reset.check.sent'|trans }}
        {{ 'reset.check.link_valid'|trans({'%duration%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')}) }}
    </p>
    <p class="muted">
        {% set retry %}<a href="{{ path('app_forgot_password_request') }}">{{ 'reset.check.retry'|trans }}</a>{% endset %}
        {{ 'reset.check.no_email'|trans({'%retry%': retry})|raw }}
    </p>
    <p class="muted"><a href="{{ path('admin_login') }}">← {{ 'reset.back_to_login'|trans }}</a></p>
{% endblock %}
