{% extends 'reset_password/_layout.html.twig' %}

{% block title %}{{ 'reset.request.title'|trans }} — Tallyst{% endblock %}

{% block body %}
    <h1>{{ 'reset.request.title'|trans }}</h1>

    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="error">{{ flash_error }}</div>
    {% endfor %}

    {{ form_start(requestForm) }}
        {{ form_row(requestForm.email, {label: 'field.email'|trans}) }}
        <p class="muted">{{ 'reset.request.intro'|trans }}</p>
        <button type="submit">{{ 'reset.request.submit'|trans }}</button>
    {{ form_end(requestForm) }}

    <p class="muted"><a href="{{ path('admin_login') }}">← {{ 'reset.back_to_login'|trans }}</a></p>
{% endblock %}
