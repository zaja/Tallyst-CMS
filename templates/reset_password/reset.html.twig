{% extends 'reset_password/_layout.html.twig' %}

{% block title %}Nova lozinka — Tallyst{% endblock %}

{% block body %}
    <h1>Nova lozinka</h1>

    {{ form_start(resetForm) }}
        {{ form_row(resetForm.plainPassword.first, {label: 'Nova lozinka'}) }}
        {{ form_row(resetForm.plainPassword.second, {label: 'Ponovi lozinku'}) }}
        <button type="submit">Spremi novu lozinku</button>
    {{ form_end(resetForm) }}
{% endblock %}
