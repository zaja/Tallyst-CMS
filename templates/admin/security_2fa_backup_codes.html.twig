{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.security.backup.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body" style="max-width: 36rem;">
            <div class="alert alert-warning">
                {{ 'admin.security.backup.warning'|trans({}, 'admin') }}
            </div>
            <pre style="font-size:1.1rem; background:#f8f9fa; padding:1rem; border-radius:8px;">{% for c in codes %}{{ c }}
{% endfor %}</pre>
            <a class="btn btn-primary" href="{{ path('admin_security') }}">{{ 'admin.security.backup.done'|trans({}, 'admin') }}</a>
        </div>
    </div>
{% endblock %}
