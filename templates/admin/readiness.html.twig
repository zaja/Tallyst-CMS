{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Provjera spremnosti{% endblock %}

{% block main %}
    <div class="alert alert-light border">
        Automatska dijagnostika postavki i spremnosti za produkciju. Panel <strong>samo javlja</strong> —
        ništa ne mijenja. Za stavke koje aplikacija ne može pouzdano provjeriti (worker, webhook, TLS)
        prikazuje se <span class="badge badge-secondary">🔍 Provjeri ručno</span> uz upute — nikad lažno
        zeleno, da zelenom možeš vjerovati.
    </div>

    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap gap-3 align-items-center">
            <strong>{{ summary.total }} provjera:</strong>
            <span><span class="badge badge-success">✅ {{ summary.ok }}</span> OK</span>
            <span><span class="badge badge-warning">⚠ {{ summary.warning }}</span> upozorenja</span>
            <span><span class="badge badge-danger">❌ {{ summary.problem }}</span> problema</span>
            <span><span class="badge badge-secondary">🔍 {{ summary.manual }}</span> ručno</span>
        </div>
    </div>

    {% for group, items in groups %}
        <div class="card mb-3">
            <div class="card-header">{{ group }}</div>
            <ul class="list-group list-group-flush">
                {% for c in items %}
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <strong>{{ c.label }}</strong>
                                <div class="text-muted small">{{ c.detail }}</div>
                                {% if c.fix %}
                                    <div class="small mt-1"><span class="text-muted">Popravak:</span> {{ c.fix }}</div>
                                {% endif %}
                            </div>
                            <span class="badge {{ c.status.badgeClass }} flex-shrink-0">{{ c.status.icon }} {{ c.status.label }}</span>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endfor %}

    {# On-demand webhook 401 self-test — FormBuilder owns the webhook routes (loose Twig coupling,
       like Postavke includes _payment_info). FormBuilder is a core module, so it's always present. #}
    {{ include('@FormBuilder/admin/_webhook_check.html.twig') }}
{% endblock %}
