{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.readiness.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {# Dark-mode polish (CSS only): the intro is a theme-aware .card (was alert-light → a light blob
       in dark). The list-group dividers used --bs-border-color, but EA's dark theme leaves that token
       LIGHT (it maps to :root's light --border-color, never overridden for dark) — so the dividers read
       bright. Use --bs-table-border-color instead (EA themes it dark in dark via --true-gray-800, the
       same token the CRUD tables use correctly); it's only defined in the dark block, so fall back to
       --bs-border-color for light mode. #}
    <style>
        .readiness-panel .list-group-item { border-color: var(--bs-table-border-color, var(--bs-border-color)); }
    </style>
    <div class="readiness-panel">
    <div class="card mb-3">
        <div class="card-body">
            {{ 'admin.readiness.intro_before'|trans({}, 'admin') }}
            <span class="badge badge-secondary">🔍 {{ 'admin.readiness.manual'|trans({}, 'admin') }}</span>
            {{ 'admin.readiness.intro_after'|trans({}, 'admin') }}
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap gap-3 align-items-center">
            <strong>{{ 'admin.readiness.summary'|trans({'%count%': summary.total}, 'admin') }}</strong>
            <span><span class="badge badge-success">✅ {{ summary.ok }}</span> {{ 'admin.readiness.ok'|trans({}, 'admin') }}</span>
            <span><span class="badge badge-warning">⚠ {{ summary.warning }}</span> {{ 'admin.readiness.warning'|trans({}, 'admin') }}</span>
            <span><span class="badge badge-danger">❌ {{ summary.problem }}</span> {{ 'admin.readiness.problem'|trans({}, 'admin') }}</span>
            <span><span class="badge badge-secondary">🔍 {{ summary.manual }}</span> {{ 'admin.readiness.manual_count'|trans({}, 'admin') }}</span>
        </div>
    </div>

    {% for group, items in groups %}
        <div class="card mb-3">
            <div class="card-header">{{ group }}</div>
            <ul class="list-group list-group-flush">
                {% for c in items %}
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <strong>{{ c.label }}</strong>
                                <div class="text-muted small">{{ c.detail }}</div>
                                {% if c.fix %}
                                    <div class="small mt-1"><span class="text-muted">{{ 'admin.readiness.fix'|trans({}, 'admin') }}</span> {{ c.fix }}</div>
                                {% endif %}
                            </div>
                            <span class="badge {{ c.status.badgeClass }} flex-shrink-0">{{ c.status.icon }} {{ ('admin.readiness.status.' ~ c.status.value)|trans({}, 'admin') }}</span>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endfor %}

    {# On-demand webhook 401 self-test — FormBuilder owns the webhook routes (loose Twig coupling,
       like Postavke includes _payment_info). FormBuilder is a core module, so it's always present. #}
    {{ include('@FormBuilder/admin/_webhook_check.html.twig') }}
    </div>
{% endblock %}
