{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.security.enable.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body" style="max-width: 36rem;">
            <ol class="mb-3">
                <li>{{ 'admin.security.enable.step1'|trans({}, 'admin') }}</li>
                <li>{{ 'admin.security.enable.step2'|trans({}, 'admin') }}</li>
            </ol>

            <p><img src="{{ qr }}" alt="{{ 'admin.security.enable.qr_alt'|trans({}, 'admin') }}" style="border:1px solid #e5e7eb; border-radius:8px;"></p>
            <p class="text-muted">{{ 'admin.security.enable.manual_hint'|trans({}, 'admin') }} <code>{{ secret }}</code></p>

            <form method="post" action="{{ path('admin_security_2fa_enable') }}" class="row g-2 align-items-end" style="max-width: 26rem;">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_enable') }}">
                <div class="col">
                    <label class="form-label" for="code">{{ 'admin.security.enable.code_label'|trans({}, 'admin') }}</label>
                    <input class="form-control" id="code" name="code" inputmode="numeric" autocomplete="one-time-code" autofocus required>
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary" type="submit">{{ 'admin.security.enable.confirm'|trans({}, 'admin') }}</button>
                </div>
            </form>

            <p class="mt-3"><a href="{{ path('admin_security') }}">{{ 'admin.security.enable.cancel'|trans({}, 'admin') }}</a></p>
        </div>
    </div>
{% endblock %}
