{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Instalirani moduli{% endblock %}

{% block main %}
    {% if modules is empty %}
        <div class="alert alert-light">
            Još nema instaliranih modula. Modul se pojavljuje ovdje čim ga dodate kao bundle
            koji implementira <code>ModuleInterface</code>.
        </div>
    {% else %}
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Modul</th>
                    <th>Verzija</th>
                    <th>Status</th>
                    <th class="text-end">Akcija</th>
                </tr>
            </thead>
            <tbody>
                {% for module in modules %}
                    <tr>
                        <td>
                            <strong>{{ module.label }}</strong><br>
                            <span class="text-muted small">{{ module.description }}</span>
                        </td>
                        <td>{{ module.version }}</td>
                        <td>
                            {% if module.core %}
                                <span class="badge badge-info">Core</span>
                            {% elseif module.enabled %}
                                <span class="badge badge-success">Uključen</span>
                            {% else %}
                                <span class="badge badge-secondary">Isključen</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            {% if module.core %}
                                <span class="text-muted small">Dio jezgre — ne može se isključiti</span>
                            {% else %}
                                <form method="post" action="{{ path('admin_modules_toggle', {name: module.name}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle-module-' ~ module.name) }}">
                                    {% if module.enabled %}
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Isključi</button>
                                    {% else %}
                                        <button class="btn btn-sm btn-primary" type="submit">Uključi</button>
                                    {% endif %}
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
