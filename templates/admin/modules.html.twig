{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.module.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {% if modules is empty %}
        <div class="alert alert-light">
            {{ 'admin.module.none'|trans({}, 'admin') }}
        </div>
    {% else %}
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>{{ 'admin.module.col.module'|trans({}, 'admin') }}</th>
                    <th>{{ 'admin.module.col.version'|trans({}, 'admin') }}</th>
                    <th>{{ 'admin.module.col.status'|trans({}, 'admin') }}</th>
                    <th class="text-end">{{ 'admin.module.col.action'|trans({}, 'admin') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for module in modules %}
                    <tr>
                        <td>
                            <strong>{{ module.label }}</strong><br>
                            <span class="text-muted small">{{ module.description|trans({}, 'admin') }}</span>
                        </td>
                        <td>{{ module.version }}</td>
                        <td>
                            {% if module.core %}
                                <span class="badge badge-info">{{ 'admin.module.badge.core'|trans({}, 'admin') }}</span>
                            {% elseif module.enabled %}
                                <span class="badge badge-success">{{ 'admin.module.badge.enabled'|trans({}, 'admin') }}</span>
                            {% else %}
                                <span class="badge badge-secondary">{{ 'admin.module.badge.disabled'|trans({}, 'admin') }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            {% if module.core %}
                                <span class="text-muted small">{{ 'admin.module.core_locked'|trans({}, 'admin') }}</span>
                            {% else %}
                                <form method="post" action="{{ path('admin_modules_toggle', {name: module.name}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle-module-' ~ module.name) }}">
                                    {% if module.enabled %}
                                        <button class="btn btn-sm btn-outline-danger" type="submit">{{ 'admin.module.button.disable'|trans({}, 'admin') }}</button>
                                    {% else %}
                                        <button class="btn btn-sm btn-primary" type="submit">{{ 'admin.module.button.enable'|trans({}, 'admin') }}</button>
                                    {% endif %}
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
