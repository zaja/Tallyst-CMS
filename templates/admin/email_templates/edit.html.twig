{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block content_title %}{{ 'admin.email.edit.title'|trans({'%label%': type.label|trans({}, 'emails')}, 'admin') }}{% endblock %}

{% block main %}
    <div class="row">
        <div class="col-lg-8">
            {{ form_start(form, {attr: {'data-dirty-guard': ''}}) }}
            <div class="card"><div class="card-body">
                {{ form_row(form.subject) }}

                {# Body: Tiptap-lite editor (email-editor controller) mounted on the textarea.
                   Raw HTML in/out — no shortcode converter. Tag buttons insert the literal {tag}. #}
                <div class="mb-3" data-controller="email-editor">
                    {{ form_label(form.body) }}
                    <div class="email-editor__toolbar">
                        <button type="button" class="email-editor__btn" data-action="email-editor#bold" title="{{ 'admin.email.edit.toolbar.bold'|trans({}, 'admin') }}"><strong>B</strong></button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#italic" title="{{ 'admin.email.edit.toolbar.italic'|trans({}, 'admin') }}"><em>I</em></button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#link" title="{{ 'admin.email.edit.toolbar.link'|trans({}, 'admin') }}">🔗</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#bulletList" title="{{ 'admin.email.edit.toolbar.bullet_list'|trans({}, 'admin') }}">• {{ 'admin.email.edit.toolbar.bullet_list'|trans({}, 'admin') }}</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#orderedList" title="{{ 'admin.email.edit.toolbar.ordered_list'|trans({}, 'admin') }}">1. {{ 'admin.email.edit.toolbar.bullet_list'|trans({}, 'admin') }}</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#h2" title="{{ 'admin.email.edit.toolbar.h2'|trans({}, 'admin') }}">H2</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#h3" title="{{ 'admin.email.edit.toolbar.h3'|trans({}, 'admin') }}">H3</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#paragraph" title="{{ 'admin.email.edit.toolbar.paragraph'|trans({}, 'admin') }}">¶</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#clearFormatting" title="{{ 'admin.email.edit.toolbar.clear'|trans({}, 'admin') }}">✖ format</button>
                        <span class="email-editor__sep" aria-hidden="true"></span>
                        {% for tag, desc in type.tags %}
                            <button type="button" class="email-editor__btn email-editor__btn--tag"
                                    data-action="email-editor#insertTag"
                                    data-email-editor-tag-param="{{ '{' ~ tag ~ '}' }}"
                                    title="{{ 'admin.email.edit.insert_tag'|trans({'%desc%': desc|trans({}, 'emails')}, 'admin') }}">{{ '{' ~ tag ~ '}' }}</button>
                        {% endfor %}
                    </div>
                    <div class="email-editor__editor" data-email-editor-target="editor"></div>
                    {{ form_widget(form.body, {attr: {'data-email-editor-target': 'input', hidden: 'hidden'}}) }}
                    {{ form_errors(form.body) }}
                </div>

                {% if form.enabled is defined %}
                    {{ form_row(form.enabled) }}
                {% else %}
                    <p class="text-muted small mb-0"><i class="fa fa-lock"></i> {{ 'admin.email.edit.required_disabled'|trans({}, 'admin') }}</p>
                {% endif %}
            </div></div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" type="submit">{{ 'admin.email.edit.save'|trans({}, 'admin') }}</button>
                <a class="btn btn-link" href="{{ path('admin_email_templates') }}">{{ 'admin.email.edit.back'|trans({}, 'admin') }}</a>
            </div>
            {{ form_end(form) }}
        </div>
        <div class="col-lg-4">
            <div class="card"><div class="card-body">
                <h3 class="h6">{{ 'admin.email.edit.tags_heading'|trans({}, 'admin') }}</h3>
                <p class="text-muted small">{{ 'admin.email.edit.tags_intro'|trans({}, 'admin') }}</p>
                <ul class="list-unstyled small mb-0">
                    {% for tag, desc in type.tags %}
                        <li class="mb-2">
                            <code>{{ '{' ~ tag ~ '}' }}</code>
                            {% if tag in type.requiredTags %}<span class="badge badge-danger">{{ 'admin.email.edit.tag_required'|trans({}, 'admin') }}</span>{% endif %}
                            <br><span class="text-muted">{{ desc|trans({}, 'emails') }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div></div>
        </div>
    </div>
{% endblock %}
