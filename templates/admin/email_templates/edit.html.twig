{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block content_title %}Email: {{ type.label }}{% endblock %}

{% block main %}
    <div class="row">
        <div class="col-lg-8">
            {{ form_start(form) }}
            <div class="card"><div class="card-body">
                {{ form_row(form.subject) }}

                {# Body: Tiptap-lite editor (email-editor controller) mounted on the textarea.
                   Raw HTML in/out — no shortcode converter. Tag buttons insert the literal {tag}. #}
                <div class="mb-3" data-controller="email-editor">
                    {{ form_label(form.body) }}
                    <div class="email-editor__toolbar">
                        <button type="button" class="email-editor__btn" data-action="email-editor#bold" title="Podebljano"><strong>B</strong></button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#italic" title="Kurziv"><em>I</em></button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#link" title="Poveznica">🔗</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#bulletList" title="Lista">• Lista</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#orderedList" title="Numerirana lista">1. Lista</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#h2" title="Naslov 2">H2</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#h3" title="Naslov 3">H3</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#paragraph" title="Paragraf">¶</button>
                        <button type="button" class="email-editor__btn" data-action="email-editor#clearFormatting" title="Očisti formatiranje">✖ format</button>
                        <span class="email-editor__sep" aria-hidden="true"></span>
                        {% for tag, desc in type.tags %}
                            <button type="button" class="email-editor__btn email-editor__btn--tag"
                                    data-action="email-editor#insertTag"
                                    data-email-editor-tag-param="{{ '{' ~ tag ~ '}' }}"
                                    title="Ubaci: {{ desc }}">{{ '{' ~ tag ~ '}' }}</button>
                        {% endfor %}
                    </div>
                    <div class="email-editor__editor" data-email-editor-target="editor"></div>
                    {{ form_widget(form.body, {attr: {'data-email-editor-target': 'input', hidden: 'hidden'}}) }}
                    {{ form_errors(form.body) }}
                </div>

                {% if form.enabled is defined %}
                    {{ form_row(form.enabled) }}
                {% else %}
                    <p class="text-muted small mb-0"><i class="fa fa-lock"></i> Ovaj e-mail je obavezan i ne može se onemogućiti.</p>
                {% endif %}
            </div></div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" type="submit">Spremi</button>
                <a class="btn btn-link" href="{{ path('admin_email_templates') }}">Natrag</a>
            </div>
            {{ form_end(form) }}
        </div>
        <div class="col-lg-4">
            <div class="card"><div class="card-body">
                <h3 class="h6">Dostupne oznake</h3>
                <p class="text-muted small">Upiši ih u naslov ili sadržaj; zamijenit će se vrijednostima pri slanju.</p>
                <ul class="list-unstyled small mb-0">
                    {% for tag, desc in type.tags %}
                        <li class="mb-2">
                            <code>{{ '{' ~ tag ~ '}' }}</code>
                            {% if tag in type.requiredTags %}<span class="badge badge-danger">obavezno</span>{% endif %}
                            <br><span class="text-muted">{{ desc }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div></div>
        </div>
    </div>
{% endblock %}
