{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.email.index.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    <p class="text-muted">{{ 'admin.email.index.intro'|trans({}, 'admin') }}</p>
    <table class="table">
        <thead>
            <tr>
                <th>{{ 'admin.email.index.col.type'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.email.index.col.status'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.email.index.col.edited'|trans({}, 'admin') }}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr>
                    <td>{{ row.type.label|trans({}, 'emails') }}</td>
                    <td>
                        {% if row.enabled %}
                            <span class="badge badge-success">{{ 'admin.email.index.badge.enabled'|trans({}, 'admin') }}</span>
                        {% else %}
                            <span class="badge badge-secondary">{{ 'admin.email.index.badge.disabled'|trans({}, 'admin') }}</span>
                        {% endif %}
                    </td>
                    <td>{{ row.overridden ? 'admin.email.index.overridden_yes'|trans({}, 'admin') : 'admin.email.index.overridden_no'|trans({}, 'admin') }}</td>
                    <td class="text-end">
                        {# Icon-only Edit (pen), matching the other admin lists. title + aria-label
                           are mandatory (a11y — no visible text). Only Edit here (templates aren't
                           deleted/previewed). Behaviour unchanged — links to the template editor. #}
                        <a class="btn btn-secondary action-edit" href="{{ path('admin_email_template_edit', {key: row.type.key}) }}"
                           title="{{ 'admin.action.edit'|trans({}, 'admin') }}" aria-label="{{ 'admin.action.edit'|trans({}, 'admin') }}">
                            <span class="icon btn-icon"><i class="fa-solid fa-pen"></i></span>
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
