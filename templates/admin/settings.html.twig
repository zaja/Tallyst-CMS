{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form '@EasyAdmin/crud/form_theme.html.twig' '@Media/admin/form/media_picker_widget.html.twig' '@Media/admin/form/tiptap_widget.html.twig' %}

{% block content_title %}{{ 'admin.settings.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {% if smtp_password_unreadable %}
        <div class="alert alert-warning">
            <i class="fa fa-triangle-exclamation"></i>
            {{ 'admin.settings.smtp_unreadable'|trans({}, 'admin') }}
        </div>
    {% endif %}

    {# Tabs are real routed pages now — plain links, the active one is driven by the current
       route (not loop.first). Each opens /admin/settings/{tab}. #}
    <ul class="nav nav-tabs mb-3" role="tablist">
        {% for tab in tabs %}
            <li class="nav-item" role="presentation">
                <a class="nav-link{{ tab.key == current.key ? ' active' : '' }}"
                   href="{{ path('admin_settings_tab', {tab: tab.key}) }}"
                   {{ tab.key == current.key ? 'aria-current="page"' : '' }}>
                    <i class="fa {{ tab.icon }}"></i> {{ tab.label|trans({}, 'admin') }}
                </a>
            </li>
        {% endfor %}
    </ul>

    {% set has_email = current.sections|filter(s => s.key == 'email')|length > 0 %}
    {# A grouped tab (>1 section) labels each sub-section; a 1:1 tab doesn't (the tab name says it). #}
    {% set multi = current.sections|length > 1 %}

    {{ form_start(form, {attr: {'data-dirty-guard': ''}}) }}
    <div class="card">
        <div class="card-body">
            {% for section in current.sections %}
                {# id = anchor target for deep-links, e.g. /admin/settings/general#maintenance. #}
                <div id="{{ section.key }}"{{ multi and not loop.first ? ' class="mt-4 pt-3 border-top"' : '' }}>
                {% if multi %}
                    <h2 class="h5 fw-semibold mb-3">
                        <i class="fa {{ section.icon }} text-muted me-1"></i>{{ section.label|trans({}, 'admin') }}
                    </h2>
                {% endif %}

                {% for def in section.definitions %}
                    {{ form_row(form[def.key]) }}
                {% endfor %}

                {% if section.key == 'email' %}
                    {# Test-mail controls live in the Email tab. The inputs belong to a
                       separate <form> (rendered after the main form via the HTML5 form=
                       attribute) so we don't nest forms. #}
                    <hr>
                    <label for="test_to" class="form-label fw-semibold">{{ 'admin.settings.test_mail.label'|trans({}, 'admin') }}</label>
                    <div class="input-group">
                        <input type="hidden" name="_token" value="{{ csrf_token('settings_test_email') }}" form="settings-test-email">
                        <input type="email" id="test_to" name="test_to" class="form-control" form="settings-test-email"
                               value="{{ test_to_default }}" placeholder="{{ 'admin.settings.test_mail.placeholder'|trans({}, 'admin') }}">
                        <button class="btn btn-secondary" type="submit" form="settings-test-email">
                            <i class="fa fa-paper-plane"></i> {{ 'admin.settings.test_mail.send'|trans({}, 'admin') }}
                        </button>
                    </div>
                    <small class="text-muted d-block mt-1">{{ 'admin.settings.test_mail.note'|trans({}, 'admin') }}</small>
                {% endif %}

                {# Payment sections: mode badge + webhook setup guide (FormBuilder-owned partial).
                   Generic over any registered provider (route convention: form_builder_webhook_<key>),
                   so a new provider never edits this Core template. #}
                {% if section.key in payment_provider_names() %}
                    {{ include('@FormBuilder/admin/_payment_info.html.twig', {
                        provider: section.key,
                        webhook_route: 'form_builder_webhook_' ~ section.key,
                        dashboard: section.label|trans({}, 'admin'),
                    }) }}
                {% endif %}

                {# Shipping catalog editor (FormBuilder-owned partial, loose-Twig include). Its inputs
                   bind to the separate <form id="settings-shipping"> below via form=, not this form. #}
                {% if section.key == 'shipping' %}
                    {{ include('@FormBuilder/admin/_shipping_methods.html.twig') }}
                {% endif %}

                {# Tax editor: master toggle + rate catalog, both bound to the separate <form id="settings-tax">
                   below via form= (one Save persists both). The tax section declares no scalar defs, so the
                   generic Save is auto-hidden — like Shipping. #}
                {% if section.key == 'tax' %}
                    {{ include('@FormBuilder/admin/_tax_rates.html.twig') }}
                {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>

    {# The generic Save writes the tab's scalar settings. Hidden on a tab with no scalar fields
       (e.g. Shipping — its own Save lives in the catalog editor) so there's no confusing no-op button. #}
    {% if current.definitions|length > 0 %}
        <div class="mt-3">
            <button class="btn btn-primary" type="submit">{{ 'admin.settings.save'|trans({}, 'admin') }}</button>
        </div>
    {% endif %}
    {{ form_end(form) }}

    {# The test-mail form: empty here (no nested forms); its inputs sit in the Email tab above
       and bind to it via the HTML5 form="settings-test-email" attribute. Only present on the
       tab that renders the email section. #}
    {% if has_email %}
        <form id="settings-test-email" method="post" action="{{ path('admin_settings_test_email') }}"></form>
    {% endif %}

    {# The shipping-catalog form: empty here (no nested forms); the catalog editor's inputs sit in the
       Shipping tab above and bind to it via form="settings-shipping". Only on the tab with that section. #}
    {% set has_shipping = current.sections|filter(s => s.key == 'shipping')|length > 0 %}
    {% if has_shipping %}
        <form id="settings-shipping" method="post" action="{{ path('admin_settings_shipping_save') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('settings_shipping') }}">
        </form>
    {% endif %}

    {# The tax-rate catalog form: empty here (no nested forms); the editor's inputs sit in the Tax tab
       above and bind to it via form="settings-tax". Only on the tab with that section. #}
    {% set has_tax = current.sections|filter(s => s.key == 'tax')|length > 0 %}
    {% if has_tax %}
        <form id="settings-tax" method="post" action="{{ path('admin_settings_tax_save') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('settings_tax') }}">
        </form>
    {% endif %}
{% endblock %}
