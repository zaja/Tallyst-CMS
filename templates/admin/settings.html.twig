{% extends '@EasyAdmin/page/content.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' '@Media/admin/form/media_picker_widget.html.twig' '@Media/admin/form/tiptap_widget.html.twig' %}

{% block content_title %}Postavke{% endblock %}

{% block main %}
    {% if smtp_password_unreadable %}
        <div class="alert alert-warning">
            <i class="fa fa-triangle-exclamation"></i>
            SMTP lozinku nije moguće dekriptirati (ključ promijenjen ili izgubljen). Mailovi
            privremeno koriste <code>MAILER_DSN</code> iz okoline. Upiši lozinku ponovno i spremi.
        </div>
    {% endif %}

    {{ form_start(form) }}
    <ul class="nav nav-tabs mb-3" role="tablist">
        {% for section in sections %}
            <li class="nav-item" role="presentation">
                <button class="nav-link{{ loop.first ? ' active' : '' }}" id="tab-{{ section.key }}"
                        data-bs-toggle="tab" data-bs-target="#pane-{{ section.key }}"
                        type="button" role="tab">
                    <i class="fa {{ section.icon }}"></i> {{ section.label }}
                </button>
            </li>
        {% endfor %}
    </ul>

    <div class="tab-content">
        {% for section in sections %}
            <div class="tab-pane fade{{ loop.first ? ' show active' : '' }}" id="pane-{{ section.key }}"
                 role="tabpanel" aria-labelledby="tab-{{ section.key }}">
                <div class="card">
                    <div class="card-body" style="max-width: 36rem;">
                        {% for def in section.definitions %}
                            {{ form_row(form[def.key]) }}
                        {% endfor %}

                        {% if section.key == 'email' %}
                            {# Test-mail controls live in the Email tab. The inputs belong to a
                               separate <form> (rendered after the main form via the HTML5 form=
                               attribute) so we don't nest forms. #}
                            <hr>
                            <label for="test_to" class="form-label fw-semibold">Pošalji test mail</label>
                            <div class="input-group">
                                <input type="hidden" name="_token" value="{{ csrf_token('settings_test_email') }}" form="settings-test-email">
                                <input type="email" id="test_to" name="test_to" class="form-control" form="settings-test-email"
                                       value="{{ test_to_default }}" placeholder="email@primjer.hr">
                                <button class="btn btn-secondary" type="submit" form="settings-test-email">
                                    <i class="fa fa-paper-plane"></i> Pošalji
                                </button>
                            </div>
                            <small class="text-muted d-block mt-1">Šalje preko trenutne konfiguracije; rezultat javlja koji je transport korišten.</small>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Spremi postavke</button>
    </div>
    {{ form_end(form) }}

    {# The test-mail form: empty here (no nested forms); its inputs sit in the Email tab above
       and bind to it via the HTML5 form="settings-test-email" attribute. #}
    <form id="settings-test-email" method="post" action="{{ path('admin_settings_test_email') }}"></form>
{% endblock %}
