{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Teme{% endblock %}

{% block main %}
    <div class="alert alert-light border">
        Teme se dodaju kopiranjem mape u <code>themes/</code> na serveru (FTP / kopiraj <code>default</code> i
        preimenuj); CMS ih automatski detektira. Svaka tema može imati <code>theme.png</code> (~880×660) kao sličicu.
    </div>

    {% if themes is empty %}
        <p class="text-muted">Nije pronađena nijedna tema.</p>
    {% else %}
        <div class="row g-3">
            {% for t in themes %}
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100">
                        <div class="ratio ratio-4x3 bg-body-secondary">
                            {% if t.hasThumbnail %}
                                <img src="{{ path('admin_themes_thumbnail', {name: t.name}) }}" alt="{{ t.label }}" style="object-fit: cover;">
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center text-muted">
                                    <span class="fs-5">{{ t.label }}</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            <h2 class="h6 mb-1">
                                {{ t.label }}
                                {% if t.active %}<span class="badge badge-success">Aktivna</span>{% endif %}
                                {% if t.isDefault %}<span class="badge badge-info">Default</span>{% endif %}
                            </h2>
                            <p class="small text-muted mb-2">
                                <code>{{ t.name }}</code>{% if t.author %} · {{ t.author }}{% endif %}{% if t.parent %} · roditelj: <code>{{ t.parent }}</code>{% endif %}
                            </p>

                            {% if t.parentMissing %}
                                <p class="small text-danger mb-2">Roditeljska tema <code>{{ t.parent }}</code> ne postoji — tema ne može raditi.</p>
                            {% elseif not t.valid %}
                                <p class="small text-danger mb-2">Nevaljana tema (nedostaje <code>layout.html.twig</code>).</p>
                            {% endif %}

                            {% if t.active %}
                                <button class="btn btn-sm btn-secondary" disabled>Aktivna</button>
                            {% elseif t.valid and not t.parentMissing %}
                                <form method="post" action="{{ path('admin_themes_activate', {name: t.name}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('activate-theme-' ~ t.name) }}">
                                    <button class="btn btn-sm btn-primary" type="submit">Aktiviraj</button>
                                </form>
                            {% else %}
                                <button class="btn btn-sm btn-primary" disabled title="Tema mora biti valjana">Aktiviraj</button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
