{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.theme.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {# Dark-mode: a theme-aware .card instead of .alert.alert-light (which is a light blob in dark) —
       same fix as the readiness intro box. #}
    <div class="card mb-3">
        <div class="card-body">
            {{ 'admin.theme.intro'|trans({}, 'admin') }}
        </div>
    </div>

    {% if themes is empty %}
        <p class="text-muted">{{ 'admin.theme.none'|trans({}, 'admin') }}</p>
    {% else %}
        <div class="row g-3">
            {% for t in themes %}
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100">
                        <div class="ratio ratio-4x3 bg-body-secondary">
                            {% if t.hasThumbnail %}
                                <img src="{{ path('admin_themes_thumbnail', {name: t.name}) }}" alt="{{ t.label }}" style="object-fit: cover;">
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center text-muted">
                                    <span class="fs-5">{{ t.label }}</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            <h2 class="h6 mb-1">
                                {{ t.label }}
                                {% if t.active %}<span class="badge badge-success">{{ 'admin.theme.badge.active'|trans({}, 'admin') }}</span>{% endif %}
                                {% if t.isDefault %}<span class="badge badge-info">{{ 'admin.theme.badge.default'|trans({}, 'admin') }}</span>{% endif %}
                            </h2>
                            <p class="small text-muted mb-2">
                                <code>{{ t.name }}</code>{% if t.author %} · {{ t.author }}{% endif %}{% if t.parent %} · {{ 'admin.theme.parent_label'|trans({}, 'admin') }} <code>{{ t.parent }}</code>{% endif %}
                            </p>

                            {% if t.parentMissing %}
                                <p class="small text-danger mb-2">{{ 'admin.theme.parent_missing'|trans({'%name%': '<code>' ~ t.parent ~ '</code>'}, 'admin')|raw }}</p>
                            {% elseif not t.valid %}
                                <p class="small text-danger mb-2">{{ 'admin.theme.invalid'|trans({}, 'admin') }}</p>
                            {% endif %}

                            {% if t.active %}
                                <button class="btn btn-sm btn-secondary" disabled>{{ 'admin.theme.button.active'|trans({}, 'admin') }}</button>
                            {% elseif t.valid and not t.parentMissing %}
                                <form method="post" action="{{ path('admin_themes_activate', {name: t.name}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('activate-theme-' ~ t.name) }}">
                                    <button class="btn btn-sm btn-primary" type="submit">{{ 'admin.theme.button.activate'|trans({}, 'admin') }}</button>
                                </form>
                            {% else %}
                                <button class="btn btn-sm btn-primary" disabled title="{{ 'admin.theme.activate_invalid_title'|trans({}, 'admin') }}">{{ 'admin.theme.button.activate'|trans({}, 'admin') }}</button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
