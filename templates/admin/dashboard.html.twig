{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.menu.dashboard'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {% for widget in widgets %}
        {{ include(widget.template, widget.data) }}
    {% else %}
        <p class="lead">{{ 'admin.dashboard.welcome'|trans({}, 'admin') }}</p>
        <p>{{ 'admin.dashboard.choose'|trans({}, 'admin') }}</p>
    {% endfor %}
{% endblock %}
