{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'admin.demo.title'|trans({}, 'admin') }}{% endblock %}

{% block main %}
    {# THE dominant message: the clean-site boundary. The single prominent thing on this page —
       we assert the boundary; the admin honours it. (alert-warning, like the maintenance banner —
       dark-mode-safe, unlike alert-light.) #}
    <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading mb-2">⚠ {{ 'admin.demo.boundary.heading'|trans({}, 'admin') }}</h5>
        <p class="mb-0">{{ 'admin.demo.boundary.body'|trans({}, 'admin') }}</p>
    </div>

    <p class="small text-muted mb-3">
        {{ 'admin.demo.intro'|trans({}, 'admin') }}
        {% if installed %}
            <span class="badge badge-success ms-1">{{ 'admin.demo.status.installed'|trans({}, 'admin') }}</span>
        {% else %}
            <span class="badge badge-secondary ms-1">{{ 'admin.demo.status.not_installed'|trans({}, 'admin') }}</span>
        {% endif %}
    </p>

    <div class="row g-3">
        {# Install — additive seed (idempotent). #}
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">{{ 'admin.demo.install.heading'|trans({}, 'admin') }}</div>
                <div class="card-body d-flex flex-column">
                    <p class="small mb-3">{{ 'admin.demo.install.summary'|trans({}, 'admin') }}</p>
                    <form method="post" action="{{ path('admin_demo_install') }}" class="mt-auto">
                        <input type="hidden" name="_token" value="{{ csrf_token('demo-install') }}">
                        <button type="submit" class="btn btn-primary">
                            {{ 'admin.demo.install.button'|trans({}, 'admin') }}
                        </button>
                        <span class="small text-muted ms-2">{{ 'admin.demo.takes_a_moment'|trans({}, 'admin') }}</span>
                    </form>
                </div>
            </div>
        </div>

        {# Uninstall — flag-based delete (--clear). #}
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">{{ 'admin.demo.delete.heading'|trans({}, 'admin') }}</div>
                <div class="card-body d-flex flex-column">
                    <p class="small mb-3">{{ 'admin.demo.delete.summary'|trans({}, 'admin') }}</p>
                    <form method="post" action="{{ path('admin_demo_delete') }}" class="mt-auto"
                          onsubmit="return confirm('{{ 'admin.demo.delete.confirm'|trans({}, 'admin')|e('js') }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('demo-delete') }}">
                        <button type="submit" class="btn btn-outline-danger">
                            {{ 'admin.demo.delete.button'|trans({}, 'admin') }}
                        </button>
                        <span class="small text-muted ms-2">{{ 'admin.demo.takes_a_moment'|trans({}, 'admin') }}</span>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# Make permanent — an ADVANCED, one-way action. Deliberately secondary: a slim row, muted text,
       a small outline button (NOT a primary CTA). #}
    <div class="card mt-3">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div class="small">
                    <strong>{{ 'admin.demo.unflag.heading'|trans({}, 'admin') }}</strong>
                    <span class="text-muted ms-1">{{ 'admin.demo.unflag.summary'|trans({}, 'admin') }}</span>
                </div>
                <form method="post" action="{{ path('admin_demo_unflag') }}"
                      onsubmit="return confirm('{{ 'admin.demo.unflag.confirm'|trans({}, 'admin')|e('js') }}');">
                    <input type="hidden" name="_token" value="{{ csrf_token('demo-unflag') }}">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        {{ 'admin.demo.unflag.button'|trans({}, 'admin') }}
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
