<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <title>{{ setting('site_name')|default('Tallyst') }} — {{ 'maintenance.title_suffix'|trans }}</title>
    {# Standalone (no theme/nav — the site is "down"); inline-styled like the reset-password pages. #}
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: #f6f7f9; color: #1c2430; margin: 0; display: flex; min-height: 100vh; align-items: center; justify-content: center; padding: 1.5rem; }
        .card { background: #fff; padding: 2.5rem; border-radius: 16px; box-shadow: 0 1px 3px rgba(0,0,0,.1); width: 100%; max-width: 520px; text-align: center; }
        .brand { font-weight: 700; font-size: 1.15rem; margin-bottom: 1.25rem; color: #1c2430; }
        .message { color: #5f6b78; line-height: 1.6; }
        .message :first-child { margin-top: 0; }
        .message :last-child { margin-bottom: 0; }
        h1 { font-size: 1.5rem; margin: 0 0 1rem; }
        a { color: #ea580c; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">{{ setting('site_name')|default('Tallyst') }}</div>
        <div class="message">{{ message|render_content }}</div>
    </div>
</body>
</html>
