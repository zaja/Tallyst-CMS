{# Code-owned (trusted) email wrapper. The admin body is injected via |raw — it was already
   safely placeholder-rendered (tag values escaped) by EmailRenderer. URLs are ABSOLUTE:
   base_url is the request host (web) or default_uri (worker). Simple, email-safe inline CSS
   (no external stylesheet, no theme assets — those don't resolve in a mail client). #}
{% set logo = branding_logo_url('medium') %}
<!DOCTYPE html>
<html lang="{{ setting('app_locale')|default('hr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ subject }}</title>
</head>
<body style="margin:0;padding:0;background:#f6f7f9;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f6f7f9;">
        <tr>
            <td align="center" style="padding:24px 12px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                       style="max-width:600px;background:#ffffff;border:1px solid #e4e7ec;border-radius:12px;overflow:hidden;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1f2328;">
                    <tr>
                        <td style="padding:20px 28px;border-bottom:1px solid #e4e7ec;">
                            {% if logo %}
                                <img src="{{ base_url }}{{ logo }}" alt="{{ site_name() }}" style="max-height:36px;width:auto;display:block;">
                            {% else %}
                                <strong style="font-size:18px;">{{ site_name() }}</strong>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:28px;font-size:15px;line-height:1.6;">
                            {{ body_html|raw }}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:18px 28px;border-top:1px solid #e4e7ec;color:#5c6570;font-size:12px;">
                            &copy; {{ 'now'|date('Y') }} {{ site_name() }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
