{% extends 'layout.html.twig' %}

{% block title %}{{ category.name }} — {{ setting('site_name')|default('Tallyst') }}{% endblock %}

{% block meta %}
    {% if category.description %}<meta name="description" content="{{ category.description }}">{% endif %}
{% endblock %}

{% block body %}
    <header class="page-header">
        <h1>{{ category.name }}</h1>
        {% if category.description %}<p class="page-meta">{{ category.description }}</p>{% endif %}
    </header>

    {{ include('_posts_list.html.twig', {posts: page.items}) }}
    {{ include('_pagination.html.twig', {page: page.page, lastPage: page.lastPage, route: 'category_show', routeParams: {slug: category.slug}}) }}

    <p class="prose"><a href="{{ path('blog_index') }}">&larr; {{ 'theme.category.all_posts'|trans }}</a></p>
{% endblock %}
