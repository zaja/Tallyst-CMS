<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Tallyst{% endblock %}</title>
    {% block meta %}{% endblock %}
    <style>
        :root { --ink: #1a1a1a; --muted: #666; --line: #ececec; --link: #2563eb; }
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; line-height: 1.6; margin: 0; color: var(--ink); }
        .container { max-width: 760px; margin: 0 auto; padding: 2rem 1.25rem; }
        a { color: var(--link); text-decoration: none; }
        a:hover { text-decoration: underline; }
        header.site, footer.site { border-color: var(--line); }
        header.site { border-bottom: 1px solid var(--line); }
        header.site .container { display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; padding-bottom: 1rem; }
        header.site nav a { margin-left: 1rem; }
        footer.site { border-top: 1px solid var(--line); color: var(--muted); font-size: .9rem; }
        article h1 { margin-top: 0; }
        time { color: var(--muted); }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body>
    <header class="site">
        <div class="container">
            <strong><a href="{{ path('home') }}">Tallyst</a></strong>
            <nav>
                <a href="{{ path('home') }}">Početna</a>
                <a href="{{ path('blog_index') }}">Blog</a>
            </nav>
        </div>
    </header>

    <main class="container">
        {% block body %}{% endblock %}
    </main>

    <footer class="site">
        <div class="container">&copy; {{ 'now'|date('Y') }} Tallyst</div>
    </footer>
</body>
</html>
