<!DOCTYPE html>
<html lang="{{ setting('app_locale')|default('hr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ setting('site_name')|default('Tallyst') }}{% endblock %}</title>
    {% if setting('site_tagline') %}<meta name="description" content="{{ setting('site_tagline') }}">{% endif %}
    {% block meta %}{% endblock %}
    <link rel="stylesheet" href="{{ theme_asset('css/theme.css') }}">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body>
    <header class="site">
        <div class="container">
            {{ render_branding() }}
            {{ render_menu('main') }}
        </div>
    </header>

    <main class="container">
        {% block body %}{% endblock %}
    </main>

    <footer class="site">
        <div class="container">&copy; {{ 'now'|date('Y') }} Tallyst</div>
    </footer>
</body>
</html>
