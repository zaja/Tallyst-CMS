<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Tallyst{% endblock %}</title>
    {% block meta %}{% endblock %}
    <link rel="stylesheet" href="{{ theme_asset('css/theme.css') }}">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body>
    <header class="site">
        <div class="container">
            <strong><a href="{{ path('home') }}">Tallyst</a></strong>
            {{ render_menu('main') }}
        </div>
    </header>

    <main class="container">
        {% block body %}{% endblock %}
    </main>

    <footer class="site">
        <div class="container">&copy; {{ 'now'|date('Y') }} Tallyst</div>
    </footer>
</body>
</html>
