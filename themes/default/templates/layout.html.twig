<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ setting('site_name')|default('Tallyst') }}{% endblock %}</title>
    {% if setting('site_tagline') %}<meta name="description" content="{{ setting('site_tagline') }}">{% endif %}
    {% if favicon_url() %}<link rel="icon" href="{{ favicon_url() }}">{% endif %}
    {% block meta %}{% endblock %}
    <link rel="stylesheet" href="{{ theme_asset('css/theme.css') }}">
    {# THEME CONTRACT: font_styles() emits the admin's chosen system fonts (@font-face + :root
       --font/--font-display override) — AFTER theme.css so it overrides the defaults. A theme that
       wants the font choice to apply must include this in its head. #}
    {{ font_styles() }}
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body>
    <a class="skip-link" href="#main">{{ 'theme.nav.skip_link'|trans }}</a>

    {# Optional thin top bar above the header (Postavke → Top bar). Left = rich text (links);
       right = social icons (one per brand whose URL is set — social_links() filters + guards the
       scheme). Placeholder layout; the real visual is Tema v2. #}
    {% if setting('top_bar_enabled') %}
        <div class="site-topbar">
            <div class="container site-topbar__inner">
                <div class="site-topbar__text">{{ setting('top_bar_text')|render_content }}</div>
                {% set socials = social_links() %}
                {% if socials %}
                    <div class="site-topbar__social">
                        {% for s in socials %}
                            <a href="{{ s.url }}" class="site-topbar__social-link">{{ icon(s.key, {label: s.key}) }}</a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# is-nav-open is toggled by nav.js (progressive enhancement); without JS the nav
       falls back to a visible nested list. #}
    <header class="site-header" data-nav>
        <div class="container">
            {{ render_branding() }}
            <button class="nav-toggle" type="button" aria-expanded="false" aria-label="{{ 'theme.nav.menu_toggle'|trans }}" aria-controls="site-nav">
                <span class="bars" aria-hidden="true"></span>
            </button>
            {{ render_menu('main') }}
            {% if setting('search_enabled') %}
                {# Live dropdown is progressive enhancement — without JS the form still submits to /pretraga. #}
                <form class="site-search" role="search" method="get" action="{{ path('search') }}"
                      data-controller="search--live"
                      data-search--live-url-value="{{ path('search_live') }}"
                      data-search--live-show-all-value="{{ 'theme.search.show_all'|trans }}"
                      data-action="keydown->search--live#keydown">
                    <input type="search" name="q" placeholder="{{ 'theme.search.placeholder'|trans }}" aria-label="{{ 'theme.search.label'|trans }}" autocomplete="off"
                           value="{{ app.request.query.get('q') }}"
                           data-search--live-target="input"
                           data-action="input->search--live#onInput">
                    <button type="submit" aria-label="{{ 'theme.search.submit'|trans }}">{{ icon('search') }}</button>
                    <div class="live-search-dropdown" role="listbox" data-search--live-target="dropdown" hidden></div>
                </form>
            {% endif %}
        </div>
    </header>

    <main id="main" class="site-main">
        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </main>

    {# Configurable footer (Postavke → Footer): 1–4 columns, each a menu (its name is the heading)
       OR rich text — the type is implicit (menu wins when both are set). Only columns up to
       footer_columns are rendered; empty columns are skipped. Branding line below. #}
    {% set footer_cols = setting('footer_columns')|default('2') %}
    {% set footer_copyright = setting('footer_copyright') %}
    <footer class="site-footer">
        <div class="container">
            {% set footer_cols_html %}
                {% for n in 1..4 %}
                    {% if n <= footer_cols %}
                        {% set col_menu = setting('footer_col' ~ n ~ '_menu') %}
                        {% set col_text = setting('footer_col' ~ n ~ '_text') %}
                        {% if col_menu %}
                            <div class="footer-col footer-col--menu">{{ render_menu(col_menu, {template: 'footer_menu.html.twig'}) }}</div>
                        {% elseif col_text %}
                            <div class="footer-col footer-col--text">{{ col_text|render_content }}</div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endset %}
            {% if footer_cols_html|trim %}
                <div class="footer-cols footer-cols--{{ footer_cols }}">{{ footer_cols_html }}</div>
            {% endif %}
            <div class="footer-branding">
                <span>{{ footer_copyright ?: '© ' ~ 'now'|date('Y') ~ ' ' ~ (setting('site_name')|default('Tallyst')) }}</span>
                {% if setting('footer_show_powered_by') %}
                    <span>{{ 'theme.footer.powered_by'|trans }} <a href="https://github.com/zaja/Tallyst-CMS" rel="noopener">Tallyst CMS</a></span>
                {% endif %}
            </div>
        </div>
    </footer>

    <script src="{{ theme_asset('js/nav.js') }}" defer></script>
</body>
</html>
