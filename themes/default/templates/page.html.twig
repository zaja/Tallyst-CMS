{% extends 'layout.html.twig' %}

{% block title %}{{ page.metaTitle ?: page.title }} — {{ setting('site_name')|default('Tallyst') }}{% endblock %}

{% block meta %}
    {% if page.metaDescription %}<meta name="description" content="{{ page.metaDescription }}">{% endif %}
{% endblock %}

{% block body %}
    {% set hero_overlay = page.heroEnabled and (page.heroTitle or page.heroText) %}
    {% set hero_image_only = page.heroEnabled and page.heroImage and not (page.heroTitle or page.heroText) %}

    {% if hero_overlay %}
        {# Hero WITH text: the image is FULL-BLEED across the whole hero; the text (h1 + text + CTA)
           sits OVER it on one 50% half (heroPosition = left/right; full-width on mobile), vertically
           centred. heroStyle = text treatment only (image always full-bleed): photo = a scrim over
           the text half + white text; light = white text (for dark images), dark = dark text (for
           light images) — both with NO panel/scrim, only a subtle text-shadow for edge contrast.
           Image is decorative (the <h1> carries meaning). Null-safe: no heroImage → the --ink
           fallback + white text keeps the overlay legible. #}
        <header class="page-hero page-hero--{{ page.heroPosition }} page-hero--{{ page.heroStyle }}{{ page.heroImage ? '' : ' page-hero--no-image' }}">
            {% if page.heroImage %}{{ media_img(page.heroImage, 'hero', null, '') }}{% endif %}
            <div class="page-hero-inner">
                <h1>{{ page.heroTitle ?: page.title }}</h1>
                {% if page.heroText %}<p class="page-hero-text">{{ page.heroText }}</p>{% endif %}
                {% if page.heroCtaLabel and page.heroCtaUrl %}
                    <a class="page-hero-cta" href="{{ page.heroCtaUrl }}">{{ page.heroCtaLabel }}</a>
                {% endif %}
            </div>
        </header>
        {# no separate page-header: the overlay carries the title #}
    {% elseif hero_image_only %}
        {# Hero with ONLY an image: show the image bare (no overlay text), and render the
           page title below in the normal header position — unless the title is hidden. #}
        <div class="page-hero-image">{{ media_img(page.heroImage, 'hero', null, '') }}</div>
        {% if not page.hideTitle %}
            <header class="page-header">
                <h1>{{ page.title }}</h1>
            </header>
        {% endif %}
    {% elseif not page.hideTitle %}
        {# Standard auto page title — suppressed when hideTitle is set, so a landing page can
           build its own heading (an H1) inside the content. The title is still used for
           <title>/meta/sitemap/admin; only this visual page-header <h1> is skipped. #}
        <header class="page-header">
            <h1>{{ page.title }}</h1>
        </header>
    {% endif %}

    {# Full-width page content: images, .tallyst-columns and the [form] embed span the
       shell; textual blocks are capped to the readable measure (see .page-content CSS). #}
    <article class="page-content">
        {% if page.featuredImage %}<p class="featured-image">{{ media_img(page.featuredImage, 'hero') }}</p>{% endif %}
        {{ page.content|render_content }}
    </article>
{% endblock %}
