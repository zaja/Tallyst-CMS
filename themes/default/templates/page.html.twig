{% extends 'layout.html.twig' %}

{% block title %}{{ page.metaTitle ?: page.title }} — {{ setting('site_name')|default('Tallyst') }}{% endblock %}

{% block meta %}
    {% if page.metaDescription %}<meta name="description" content="{{ page.metaDescription }}">{% endif %}
{% endblock %}

{% block body %}
    <article class="prose">
        <header class="page-header">
            <h1>{{ page.title }}</h1>
        </header>
        {% if page.featuredImage %}<p class="featured-image">{{ media_img(page.featuredImage, 'medium') }}</p>{% endif %}
        {{ page.content|render_content }}
    </article>
{% endblock %}
