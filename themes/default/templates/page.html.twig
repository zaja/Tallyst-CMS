{% extends 'layout.html.twig' %}

{% block title %}{{ page.metaTitle ?: page.title }} — Tallyst{% endblock %}

{% block meta %}
    {% if page.metaDescription %}<meta name="description" content="{{ page.metaDescription }}">{% endif %}
{% endblock %}

{% block body %}
    <article>
        <h1>{{ page.title }}</h1>
        {{ page.content|render_content }}
    </article>
{% endblock %}
