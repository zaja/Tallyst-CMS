{% extends 'layout.html.twig' %}

{% block title %}{{ 'theme.blog.title'|trans }} — {{ setting('site_name')|default('Tallyst') }}{% endblock %}

{% block body %}
    <header class="page-header">
        <h1>{{ 'theme.blog.title'|trans }}</h1>
    </header>

    {{ include('_posts_list.html.twig', {posts: page.items}) }}
    {{ include('_pagination.html.twig', {page: page.page, lastPage: page.lastPage, route: 'blog_index', routeParams: {}}) }}
{% endblock %}
