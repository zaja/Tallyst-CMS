{% extends 'layout.html.twig' %}

{% block title %}{{ post.title }} — Tallyst{% endblock %}

{% block body %}
    <article>
        <h1>{{ post.title }}</h1>
        {% if post.publishedAt %}
            <p><time datetime="{{ post.publishedAt|date('c') }}">{{ post.publishedAt|date('d.m.Y.') }}</time></p>
        {% endif %}
        {{ post.content|render_content }}
    </article>

    <p><a href="{{ path('blog_index') }}">&larr; Natrag na blog</a></p>
{% endblock %}
