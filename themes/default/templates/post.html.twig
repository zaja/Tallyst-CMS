{% extends 'layout.html.twig' %}

{% block title %}{{ post.title }} — {{ setting('site_name')|default('Tallyst') }}{% endblock %}

{% block body %}
    <article class="prose">
        <header class="page-header">
            <h1>{{ post.title }}</h1>
            {% set has_byline = post.author and post.author.nickname %}
            {% if post.publishedAt or post.category or has_byline %}
                <p class="page-meta post-meta">
                    {% if post.publishedAt %}<time datetime="{{ post.publishedAt|date('c') }}">{{ app_date(post.publishedAt) }}</time>{% endif %}
                    {% if has_byline %}{{ post.publishedAt ? ' · ' : '' }}{{ 'theme.post.byline'|trans({'%author%': post.author.nickname}) }}{% endif %}
                    {% if post.category %} · <a href="{{ path('category_show', {slug: post.category.slug}) }}">{{ post.category.name }}</a>{% endif %}
                </p>
            {% endif %}
        </header>
        {% if post.featuredImage %}<p class="featured-image">{{ media_img(post.featuredImage, 'medium') }}</p>{% endif %}
        {{ post.content|render_content }}
    </article>

    {% if prev or next %}
        <nav class="post-nav prose" aria-label="{{ 'theme.pagination.label'|trans }}">
            {% if prev %}
                <a class="post-nav-link post-nav-prev" href="{{ path('blog_post', {slug: prev.slug}) }}" rel="prev">
                    {% if prev.featuredImage %}<span class="post-nav-thumb">{{ media_img(prev.featuredImage, 'thumb') }}</span>{% endif %}
                    <span class="post-nav-text">
                        <span class="post-nav-label">{{ icon('chevron-left') }} {{ 'theme.post.previous'|trans }}</span>
                        <span class="post-nav-title">{{ prev.title }}</span>
                    </span>
                </a>
            {% endif %}
            {% if next %}
                <a class="post-nav-link post-nav-next" href="{{ path('blog_post', {slug: next.slug}) }}" rel="next">
                    {% if next.featuredImage %}<span class="post-nav-thumb">{{ media_img(next.featuredImage, 'thumb') }}</span>{% endif %}
                    <span class="post-nav-text">
                        <span class="post-nav-label">{{ 'theme.post.next'|trans }} {{ icon('chevron-right') }}</span>
                        <span class="post-nav-title">{{ next.title }}</span>
                    </span>
                </a>
            {% endif %}
        </nav>
    {% endif %}

    <p class="prose"><a href="{{ path('blog_index') }}">{{ icon('arrow-left') }} {{ 'theme.post.back_to_blog'|trans }}</a></p>
{% endblock %}
