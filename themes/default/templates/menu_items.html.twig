{# Recursive menu list. items: [{label, url, active, children}]. depth: nesting level.
   Parents with children get a .submenu-toggle button driving the desktop dropdown /
   mobile accordion (see theme.css + nav.js). Degrades to a plain nested list with no JS. #}
<ul class="menu{{ depth > 0 ? ' submenu' : '' }}">
    {% for item in items %}
        {% set has_children = item.children is not empty %}
        <li class="menu-item{{ has_children ? ' has-children' : '' }}{{ item.active ? ' is-active' : '' }}">
            <a href="{{ item.url }}">{{ item.label }}</a>
            {% if has_children %}
                <button class="submenu-toggle" type="button" aria-expanded="false"
                        aria-label="{{ 'theme.nav.submenu_toggle'|trans }}: {{ item.label }}">
                    {# .caret stays as the rotation hook ([aria-expanded="true"] .caret in theme.css);
                       the glyph is the registry chevron now, not a CSS border triangle. #}
                    <span class="caret" aria-hidden="true">{{ icon('chevron-down') }}</span>
                </button>
                {{ include('menu_items.html.twig', {items: item.children, depth: depth + 1}) }}
            {% endif %}
        </li>
    {% endfor %}
</ul>
