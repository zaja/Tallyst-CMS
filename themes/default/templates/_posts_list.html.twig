{# Shared blog/archive card grid. Input: `posts` (Post[]). Reused by the blog index and
   category archives. Category link → category archive (category_show). #}
{% if posts is empty %}
    <p>{{ 'theme.blog.no_posts'|trans }}</p>
{% else %}
    <ul class="post-list">
        {% for post in posts %}
            <li class="post-card">
                {% if post.featuredImage %}
                    <a href="{{ path('blog_post', {slug: post.slug}) }}" class="post-card-media" aria-hidden="true" tabindex="-1">
                        {{ media_img(post.featuredImage, 'medium') }}
                    </a>
                {% endif %}
                <div class="post-card-body">
                    <h2><a href="{{ path('blog_post', {slug: post.slug}) }}">{{ post.title }}</a></h2>
                    {% if post.publishedAt %}
                        <p class="post-meta">
                            <time datetime="{{ post.publishedAt|date('c') }}">{{ app_date(post.publishedAt) }}</time>
                            {% if post.category %} · <a href="{{ path('category_show', {slug: post.category.slug}) }}">{{ post.category.name }}</a>{% endif %}
                        </p>
                    {% endif %}
                    {% if post.excerpt %}<p class="post-excerpt">{{ post.excerpt }}</p>{% endif %}
                </div>
            </li>
        {% endfor %}
    </ul>
{% endif %}
